---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";
import ViewBlog from "../components/about_section/VisitBlog";
import ViewAboutMe from "../components/about_section/VisitAboutMe";
import BookConsultation from "../components/about_section/VisitLuniv";
import Tooltip from "../components/navbar/Tooltip";
import RecentPosts from "../components/post_section/RecentBlogs";
import FilterTags from "../components/post_section/FilterTags";
import LinkPreview from "../components/post_section/LinkPreview.astro";

const { frontmatter } = Astro.props;
const rawPosts = await Astro.glob("../pages/posts/*.md");

const posts = rawPosts.map((post) => ({
  frontmatter: {
    title: post.frontmatter.title,
    date: post.frontmatter.date,
    description: post.frontmatter.description,
    tags: post.frontmatter.tags || [],
  },
  url: post.url || "",
}));

const { title, date, img_path, img_alt, tags } = frontmatter;
const selectedTag = Astro.url.searchParams.get("selectedTag");

const filteredPosts = selectedTag
  ? posts.filter((post) => post.frontmatter.tags.includes(selectedTag))
  : posts;
---

<script is:inline>
  function setupArticleFeatures() {
    const article = document.getElementById("article");
    if (!article) return;

    const timeEl = document.getElementById("time");
    if (timeEl) {
      const text = article.textContent || "";
      const words = text.trim().split(/\s+/).filter(Boolean).length;
      const minutes = Math.max(1, Math.ceil(words / 175));
      timeEl.textContent = String(minutes);
    }

    const tocList = document.getElementById("toc-list");
    if (tocList) {
      tocList.innerHTML = "";

      const headings = article.querySelectorAll("h2, h3");

      if (!headings.length) {
        tocList.innerHTML =
          '<p class="opacity-60 text-sm">No headings found.</p>';
        return;
      }

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id =
            heading.textContent
              ?.toLowerCase()
              .trim()
              .replace(/[^\w\s-]/g, "")
              .replace(/\s+/g, "-") || `heading-${index}`;
        }

        const link = document.createElement("a");
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent || "";
        link.className =
          heading.tagName === "H2"
            ? "block py-1 hover:underline"
            : "block py-1 pl-5 text-sm opacity-80 hover:underline";

        tocList.appendChild(link);
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupArticleFeatures);
  } else {
    setupArticleFeatures();
  }

  document.addEventListener("astro:page-load", setupArticleFeatures);
  document.addEventListener("astro:after-swap", setupArticleFeatures);
</script>

<BaseLayout title={title}>
  <main class="pt-20 lg:pt-24 w-full max-w-5xl mx-auto px-4">
    <details class="mb-8 w-full rounded-lg border border-[#202020]/15 dark:border-[#7c8fd1]/30 bg-white dark:bg-[#111827] overflow-hidden group">
      <summary class="flex cursor-pointer list-none items-center justify-between px-5 py-4 font-semibold text-[#202020] dark:text-[#7c8fd1]">
        <span>Table of Contents</span>
        <span class="transition-transform duration-300 group-open:rotate-180">^</span>
      </summary>
      <div class="border-t border-[#202020]/10 dark:border-[#7c8fd1]/20 px-5 py-4">
        <nav id="toc-list" class="flex flex-col text-[#202020] dark:text-[#96a6e2]"></nav>
      </div>
    </details>

    <div class="mb-8 w-full">
      <h1 class="text-3xl font-semibold lg:text-4xl text-[#202020] dark:text-[#7c8fd1] break-words">{title}</h1>
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mt-4">
        <Tooltip text="At 175 words per minute." position="left">
          <p class="text-sm lg:text-base text-[#202020] dark:text-[#96a6e2]">
            <span id="time" class="font-bold"></span> min read
          </p>
        </Tooltip>
        <p class="text-sm lg:text-base flex gap-2 text-[#202020] dark:text-[#96a6e2]">
          <span>{date}</span>
          <a href="/posts" class="ml-2 hover:underline">Back to posts</a>
        </p>
      </div>

      {img_path && (
        <Image
          src={img_path}
          alt={img_alt || title}
          class="w-full object-cover rounded lg:rounded-lg h-64 lg:h-96 mt-6"
          width={800}
          height={400}
        />
      )}

      <h2 class="text-md lg:text-lg mt-4 opacity-80 text-[#202020] dark:text-[#7c8fd1]">
        {frontmatter.description || "An insightful blog post."}
      </h2>
    </div>

    <div class="mb-8">
      <FilterTags tags={tags} onClick={(tag: string) => { window.location.href = `?selectedTag=${tag}`; }} />
    </div>

    <div class="mb-12 border-y border-[#202020]/10 dark:border-[#7c8fd1]/20 py-4">
      <div class="flex flex-wrap items-center gap-4">
        <span class="text-sm font-semibold text-[#202020] dark:text-[#7c8fd1]">Share</span>
        <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm hover:underline"><i class="fab fa-x-twitter"></i> X</a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm hover:underline"><i class="fab fa-facebook"></i> Facebook</a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm hover:underline"><i class="fab fa-linkedin"></i> LinkedIn</a>
        <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm hover:underline"><i class="fab fa-reddit"></i> Reddit</a>
        <a href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(Astro.url.href)}`} class="inline-flex items-center gap-2 text-sm hover:underline"><i class="fas fa-envelope"></i> Email</a>
        <button type="button" onclick="navigator.clipboard.writeText(window.location.href)" class="inline-flex items-center gap-2 text-sm text-[#202020] dark:text-[#96a6e2] hover:underline"><i class="fas fa-link"></i> Copy Link</button>
      </div>
    </div>

    <div class="flex flex-col lg:flex-row lg:gap-16 w-full">
      <div class="w-full lg:w-2/3">
        <div id="article" class="prose dark:prose-invert max-w-none text-[#202020] dark:text-[#96a6e2]">
          <slot />
        </div>
        <div class="mt-8">
          <LinkPreview />
        </div>
      </div>

      <aside class="w-full lg:w-1/3 mt-12 lg:mt-0">
        <div class="border border-[#202020] dark:border-[#7c8fd1] p-6 rounded">
          <div class="flex items-center py-2">
            <Image src={info.picture} alt={info.picture_alt} class="mr-3 h-12 w-12 rounded-full object-cover" height={48} width={48} />
            <div>
              <p class="text-xs font-semibold text-[#202020]/70 dark:text-[#96a6e2]/70">Author</p>
              <a class="text-sm font-bold text-[#202020] dark:text-[#7c8fd1] hover:underline" href="/">{info.name}</a>
            </div>
          </div>
          <p class="py-3 text-sm text-[#202020] dark:text-[#96a6e2]">{info.brief_description}</p>
          <Contact contact={info.contact} size="md" />
        </div>
        <div class="mt-8">
          <RecentPosts posts={filteredPosts} />
          <div class="text-center pt-4"><BookConsultation /></div>
          <div class="flex flex-col gap-2 mt-4"><ViewBlog /><ViewAboutMe /></div>
        </div>
      </aside>
    </div>
<section class="pt-6">
  <h2 class="text-xl font-semibold text-[#202020] dark:text-[#7c8fd1] mb-4">
    Notes from Nick
  </h2>

  <ul class="list-disc space-y-2 pl-5">
    <li class="text-[#202020] dark:text-[#7c8fd1]">
      Stay up to date with my latest posts via
      <a class="text-[#202020] dark:text-[#7c8fd1] underline" href="/rss.xml">RSS</a>
    </li>
    <li class="text-[#202020] dark:text-[#7c8fd1]">
      Have a question or want to discuss a topic?
      <a class="text-[#202020] dark:text-[#7c8fd1] underline" href="mailto:nickstambaugh@proton.me">Email me</a>
    </li>
    <li class="text-[#202020] dark:text-[#7c8fd1]">
      Interested in working together? Visit
      <a class="text-[#202020] dark:text-[#7c8fd1] underline" href="https://luniv.tech">Luniv Technology</a>
    </li>
  </ul>
</section>
  </main>
</BaseLayout>
