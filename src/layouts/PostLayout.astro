---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import { info } from "../data/info";
import Contact from "../components/contact_section/Contact";
import ViewBlog from "../components/about_section/VisitBlog";
import ViewAboutMe from "../components/about_section/VisitAboutMe";
import BookConsultation from "../components/about_section/VisitLuniv";
import Tooltip from "../components/navbar/Tooltip";
import RecentPosts from "../components/post_section/RecentBlogs";
import FilterTags from "../components/post_section/FilterTags";
import LinkPreview from "../components/post_section/LinkPreview.astro";

const { frontmatter } = Astro.props;
const rawPosts = await Astro.glob("../pages/posts/*.md");

const posts = rawPosts.map((post) => ({
  frontmatter: {
    title: post.frontmatter.title,
    date: post.frontmatter.date,
    description: post.frontmatter.description,
    tags: post.frontmatter.tags || [],
  },
  url: post.url || "",
}));

const { title, date, img_path, img_alt, tags } = frontmatter;
const selectedTag = Astro.url.searchParams.get("selectedTag");

const filteredPosts = selectedTag
  ? posts.filter((post) => post.frontmatter.tags.includes(selectedTag))
  : posts;
---

<script is:inline defer>
  function readingTime() {
    const article = document.getElementById("article");
    if (!article) return;
    const text = article.innerText || "";
    const wpm = 175;
    const words = text.trim().split(/\s+/).filter(Boolean).length;
    const time = Math.max(1, Math.ceil(words / wpm));
    document.getElementById("time").innerText = time.toString();
  }

  function buildTOC() {
    const article = document.getElementById("article");
    const toc = document.getElementById("toc-list");

    if (!article || !toc) return;

    const headings = article.querySelectorAll("h2, h3");

    headings.forEach((heading, index) => {
      if (!heading.id) {
        heading.id = `heading-${index}`;
      }

      const a = document.createElement("a");
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent || "";
      a.className =
        heading.tagName === "H2"
          ? "block py-1 hover:underline"
          : "block py-1 pl-5 text-sm opacity-80 hover:underline";

      toc.appendChild(a);
    });

    if (!headings.length) {
      toc.innerHTML =
        '<p class="opacity-60 text-sm">No headings found.</p>';
    }
  }

  window.onload = () => {
    readingTime();
    buildTOC();
  };
</script>

<BaseLayout title={title}>
  <main class="mt-8 lg:mt-24 pt-20 lg:pt-24 w-full max-w-5xl mx-auto px-4">
    <details
      class="mb-8 w-full rounded-lg border border-[#202020]/15 dark:border-[#7c8fd1]/30 bg-white dark:bg-[#111827] overflow-hidden group"
    >
      <summary class="flex cursor-pointer list-none items-center justify-between px-5 py-4 font-semibold text-[#202020] dark:text-[#7c8fd1]">
        <span>Table of Contents</span>
        <span class="transition-transform duration-300 group-open:rotate-180">
          ^
        </span>
      </summary>

      <div
        class="border-t border-[#202020]/10 dark:border-[#7c8fd1]/20 px-5 py-4"
      >
        <nav
          id="toc-list"
          class="flex flex-col text-[#202020] dark:text-[#96a6e2]"
        ></nav>
      </div>
    </details>

    <div class="mb-8 w-full overflow-visible">
      <h1
        class="text-3xl font-semibold lg:text-4xl text-[#202020] dark:text-[#7c8fd1] break-words"
      >
        {title}
      </h1>

      <div
        class="flex flex-col lg:flex-row lg:items-center lg:justify-between mt-4"
      >
        <Tooltip text="At 175 words per minute." position="left">
          <p class="text-sm lg:text-base text-[#202020] dark:text-[#96a6e2]">
            <span id="time" class="font-bold"></span> min read
          </p>
        </Tooltip>

        <p
          class="text-sm lg:text-base flex gap-2 text-[#202020] dark:text-[#96a6e2]"
        >
          <span>{date}</span>
          <a href="/posts" class="ml-2 hover:underline">Back to posts</a>
        </p>
      </div>

      {
        img_path && (
          <Image
            src={img_path}
            alt={img_alt || title}
            class="w-full object-cover rounded lg:rounded-lg h-64 lg:h-96 mt-6"
            width={800}
            height={400}
          />
        )
      }

      <h2
        class="text-md lg:text-lg mt-4 opacity-80 text-[#202020] dark:text-[#7c8fd1]"
      >
        {frontmatter.description || "An insightful blog post."}
      </h2>
    </div>

    <div class="w-full mb-12" id="filter-tags">
      <FilterTags
        tags={tags}
        onClick={(tag) => {
          location.href = `?selectedTag=${tag}`;
        }}
      />
    </div>

    <div class="flex flex-col lg:flex-row lg:gap-16 w-full">
      <div class="w-full lg:w-2/3">
        <div
          id="article"
          class="prose dark:prose-invert max-w-none text-[#202020] dark:text-[#96a6e2]"
        >
          <slot />
        </div>

        <LinkPreview />
      </div>

      <aside class="w-full lg:w-1/3 mt-12 lg:mt-0">
        <div class="border border-[#202020] dark:border-[#7c8fd1] p-6 rounded">
          <div class="flex items-center py-2">
            <Image
              src={info.picture}
              alt={info.picture_alt}
              class="mr-3 h-12 w-12 rounded-full object-cover"
              height={48}
              width={48}
            />
            <div>
              <p
                class="text-xs font-semibold text-[#202020]/70 dark:text-[#96a6e2]/70"
              >
                Author
              </p>

              <a
                class="text-sm font-bold text-[#202020] dark:text-[#7c8fd1] hover:underline"
                href="/"
              >
                {info.name}
              </a>
            </div>
          </div>

          <p class="py-3 text-sm text-[#202020] dark:text-[#96a6e2]">
            {info.brief_description}
          </p>

          <Contact contact={info.contact} size="md" />
        </div>

        <div class="mt-8">
          <RecentPosts posts={filteredPosts} />

          <div class="text-center pt-4">
            <BookConsultation />
          </div>

          <div class="flex flex-col gap-2 mt-4">
            <ViewBlog />
            <ViewAboutMe />
          </div>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
