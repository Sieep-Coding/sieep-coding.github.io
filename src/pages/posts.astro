---
import BaseLayout from "../layouts/BaseLayout.astro";
import Post from "../components/post_section/Post.astro";

const allPosts = await Astro.glob("../pages/posts/*.md");

allPosts.sort((a, b) => {
  const A = new Date(a.frontmatter.date).getTime();
  const B = new Date(b.frontmatter.date).getTime();
  return (isNaN(B) ? 0 : B) - (isNaN(A) ? 0 : A);
});

// Build tag set
const tags = new Set();
for (const p of allPosts) {
  (p.frontmatter.tags || []).forEach(t => tags.add(t));
}

const slug = (t) =>
  t.toLowerCase().trim().replace(/[^\w\s-]/g, "").replace(/[\s_-]+/g, "-");

const title = "Posts";

// --- Header stats: total post count + monthly activity sparkline ---
const totalCount = allPosts.length;

const monthKey = (d) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
const monthLabel = (key) => {
  const [y, m] = key.split("-").map(Number);
  return new Date(y, m - 1, 1).toLocaleDateString("en-US", { month: "short", year: "2-digit" });
};

const counts = new Map();
for (const p of allPosts) {
  const d = new Date(p.frontmatter.date);
  if (isNaN(d.getTime())) continue;
  const key = monthKey(d);
  counts.set(key, (counts.get(key) || 0) + 1);
}

const sortedKeys = Array.from(counts.keys()).sort();
const bucketKeys = sortedKeys.slice(-18); // last 18 active months
const values = bucketKeys.map((k) => counts.get(k) || 0);

const sparkWidth = 320;
const sparkHeight = 72;
const padX = 6;
const padY = 10;
const max = Math.max(1, ...values);
const step = values.length > 1 ? (sparkWidth - padX * 2) / (values.length - 1) : 0;

const points = values.map((v, i) => {
  const x = padX + i * step;
  const y = sparkHeight - padY - (v / max) * (sparkHeight - padY * 2);
  return { x, y, v, key: bucketKeys[i] };
});

const linePath = points.length > 1
  ? `M${points.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" L")}`
  : "";

const areaPath = points.length > 1
  ? `${linePath} L${points[points.length - 1].x.toFixed(1)},${sparkHeight - padY} L${points[0].x.toFixed(1)},${sparkHeight - padY} Z`
  : "";

const lastPoint = points[points.length - 1];
---
<BaseLayout title={title}>
  <div class="mx-auto max-w-4xl px-4 mt-4 sm:mt-8">

    <header class="mb-12 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-8">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-text/40 dark:text-dk-text/40 mb-2">
          By <a href="/about" class="font-medium text-text dark:text-dk-text">Nick Stambaugh</a>
        </p>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-text dark:text-dk-accent leading-none">
          Posts
        </h1>
        <p class="mt-3 text-sm text-text/60 dark:text-dk-text/60">
          <span class="font-bold text-text dark:text-dk-text tabular-nums">{totalCount}</span> posts written{bucketKeys.length > 0 && (
            <>
              {" "}· latest in <span class="font-medium">{monthLabel(bucketKeys[bucketKeys.length - 1])}</span>
            </>
          )}
        </p>
      </div>

      {linePath && (
        <div class="shrink-0 w-full sm:w-80">
          <div class="flex items-center justify-between mb-1 text-[10px] uppercase tracking-widest font-bold text-text/40 dark:text-dk-text/40">
            <span>Writing activity</span>
            <span>{bucketKeys.length} mo</span>
          </div>
          <svg
            viewBox={`0 0 ${sparkWidth} ${sparkHeight}`}
            class="w-full h-auto overflow-visible"
            preserveAspectRatio="none"
            role="img"
            aria-label="Posts published per month over time"
          >
            <path
              d={areaPath}
              fill="currentColor"
              class="text-secondary/10 dark:text-dk-accent/10"
            />
            <path
              d={linePath}
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary dark:text-dk-accent"
            />
            {points.map((p) => (
              <circle
                cx={p.x}
                cy={p.y}
                r={p === lastPoint ? 3 : 1.6}
                fill="currentColor"
                class={p === lastPoint ? "text-secondary dark:text-dk-accent" : "text-text/30 dark:text-dk-text/30"}
              >
                <title>{`${monthLabel(p.key)}: ${p.v} post${p.v === 1 ? "" : "s"}`}</title>
              </circle>
            ))}
          </svg>
          <div class="mt-1 flex justify-between text-[10px] text-text/30 dark:text-dk-text/30">
            <span>{monthLabel(bucketKeys[0])}</span>
            <span>{monthLabel(bucketKeys[bucketKeys.length - 1])}</span>
          </div>
        </div>
      )}
    </header>

    <!-- High-Contrast Search & Action Container -->
    <div class="relative flex items-center mb-4 border-b-2 border-text/40 dark:border-dk-text/40 focus-within:border-secondary dark:focus-within:border-dk-accent transition-colors pb-1">
      <input
        id="post-search"
        type="text"
        placeholder="Search posts..."
        class="w-full py-3 bg-transparent text-text dark:text-dk-accent placeholder-text/60 dark:placeholder-dk-text/60 focus:outline-none text-xl font-medium tracking-wide"
      />
      
      <button
        id="filters-toggle"
        class="ml-4 px-4 py-2 text-sm uppercase font-bold tracking-widest text-text dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors focus:outline-none flex items-center gap-1"
      >
        <span>Tags</span>
        <span id="filters-arrow" class="inline-block transition-transform duration-200 text-xs">↓</span>
      </button>
    </div>

    <!-- Collapsible Tag Panel -->
    <div
      id="filters-panel"
      class="overflow-hidden transition-[max-height] duration-200 ease-out max-h-0"
    >
      <div id="tag-filter" class="flex flex-wrap gap-x-6 gap-y-3 pt-3 pb-8 border-b-2 border-text/10 dark:border-dk-text/10">
        <button
          data-filter="*"
          class="tag-btn text-sm lowercase font-bold tracking-wide text-text/70 dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 decoration-transparent underline-offset-8"
        >
          all
        </button>

        {
          Array.from(tags).map(tag => (
            <button
              data-filter={`.${slug(tag)}`}
              class="tag-btn text-sm lowercase font-bold tracking-wide text-text/70 dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 decoration-transparent underline-offset-8"
            >
              {tag}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Content Grid Layout -->
    <div
      id="posts-grid"
      class="grid gap-x-6 gap-y-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 pt-12"
    >
      {
        allPosts.map((post) => {
          const tagClasses = (post.frontmatter.tags || [])
            .map(t => slug(t))
            .join(" ");

          const title = post.frontmatter.title || "";
          const tagsStr = (post.frontmatter.tags || []).join(",");

          return (
            <div
              class={`flex post-item ${tagClasses}`}
              data-title={title.toLowerCase()}
              data-tags={tagsStr.toLowerCase()}
            >
              <Post post={post} />
            </div>
          );
        })
      }
    </div>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const searchEl = document.getElementById("post-search");
      const tagButtons = Array.from(document.querySelectorAll(".tag-btn"));
      const posts = Array.from(document.querySelectorAll(".post-item"));

      let activeFilter = "*";

      const applyFilters = () => {
        const query = searchEl.value.toLowerCase();

        posts.forEach(post => {
          const t = post.dataset.title;
          const tags = post.dataset.tags;
          const textMatch = t.includes(query) || tags.includes(query);
          const filterMatch =
            activeFilter === "*" ||
            post.classList.contains(activeFilter.slice(1));

          post.style.display = textMatch && filterMatch ? "flex" : "none";
        });
      };

      tagButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          tagButtons.forEach(b => {
            b.classList.remove("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
            b.classList.add("text-text/70", "dark:text-dk-text");
          });
          
          btn.classList.remove("text-text/70", "dark:text-dk-text");
          btn.classList.add("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
          
          activeFilter = btn.dataset.filter;
          applyFilters();
        });
      });

      searchEl.addEventListener("input", applyFilters);

      /* Collapsible Panel */
      const panel = document.getElementById("filters-panel");
      const toggle = document.getElementById("filters-toggle");
      const arrow = document.getElementById("filters-arrow");

      let open = false; 
      panel.style.maxHeight = "0px";

      toggle.addEventListener("click", () => {
        open = !open;
        if (open) {
          panel.style.maxHeight = panel.scrollHeight + "px";
          arrow.style.transform = "rotate(180deg)";
        } else {
          panel.style.maxHeight = "0px";
          arrow.style.transform = "rotate(0deg)";
        }
      });

      // Style initial high-contrast state for 'all' button explicitly on load
      const allBtn = document.querySelector('[data-filter="*"]');
      if(allBtn) {
        allBtn.classList.remove("text-text/70", "dark:text-dk-text");
        allBtn.classList.add("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
      }

      applyFilters();
    });
  </script>
</BaseLayout>