---
import BaseLayout from "../layouts/BaseLayout.astro";
import Post from "../components/post_section/Post.astro";

const allPosts = await Astro.glob("../pages/posts/*.md");

allPosts.sort((a, b) => {
  const A = new Date(a.frontmatter.date).getTime();
  const B = new Date(b.frontmatter.date).getTime();
  return (isNaN(B) ? 0 : B) - (isNaN(A) ? 0 : A);
});

// Build tag set
const tags = new Set();
for (const p of allPosts) {
  (p.frontmatter.tags || []).forEach(t => tags.add(t));
}

const slug = (t) =>
  t.toLowerCase().trim().replace(/[^\w\s-]/g, "").replace(/[\s_-]+/g, "-");

const title = "Posts";
---
<BaseLayout title={title}>
  <div class="mx-auto max-w-4xl px-4 mt-32">

    <!-- High-Contrast Search & Action Container -->
    <div class="relative flex items-center mb-4 border-b-2 border-text/40 dark:border-dk-text/40 focus-within:border-secondary dark:focus-within:border-dk-accent transition-colors pb-1">
      <input
        id="post-search"
        type="text"
        placeholder="Search posts..."
        class="w-full py-3 bg-transparent text-text dark:text-dk-accent placeholder-text/60 dark:placeholder-dk-text/60 focus:outline-none text-xl font-medium tracking-wide"
      />
      
      <button
        id="filters-toggle"
        class="ml-4 px-4 py-2 text-sm uppercase font-bold tracking-widest text-text dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors focus:outline-none flex items-center gap-1"
      >
        <span>Tags</span>
        <span id="filters-arrow" class="inline-block transition-transform duration-200 text-xs">↓</span>
      </button>
    </div>

    <!-- Collapsible Tag Panel -->
    <div
      id="filters-panel"
      class="overflow-hidden transition-[max-height] duration-200 ease-out max-h-0"
    >
      <div id="tag-filter" class="flex flex-wrap gap-x-6 gap-y-3 pt-3 pb-8 border-b-2 border-text/10 dark:border-dk-text/10">
        <button
          data-filter="*"
          class="tag-btn text-sm lowercase font-bold tracking-wide text-text/70 dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 decoration-transparent underline-offset-8"
        >
          all
        </button>

        {
          Array.from(tags).map(tag => (
            <button
              data-filter={`.${slug(tag)}`}
              class="tag-btn text-sm lowercase font-bold tracking-wide text-text/70 dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 decoration-transparent underline-offset-8"
            >
              {tag}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Content Grid Layout -->
    <div
      id="posts-grid"
      class="grid gap-x-6 gap-y-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 pt-12"
    >
      {
        allPosts.map((post) => {
          const tagClasses = (post.frontmatter.tags || [])
            .map(t => slug(t))
            .join(" ");

          const title = post.frontmatter.title || "";
          const tagsStr = (post.frontmatter.tags || []).join(",");

          return (
            <div
              class={`flex post-item ${tagClasses}`}
              data-title={title.toLowerCase()}
              data-tags={tagsStr.toLowerCase()}
            >
              <Post post={post} />
            </div>
          );
        })
      }
    </div>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const searchEl = document.getElementById("post-search");
      const tagButtons = Array.from(document.querySelectorAll(".tag-btn"));
      const posts = Array.from(document.querySelectorAll(".post-item"));

      let activeFilter = "*";

      const applyFilters = () => {
        const query = searchEl.value.toLowerCase();

        posts.forEach(post => {
          const t = post.dataset.title;
          const tags = post.dataset.tags;
          const textMatch = t.includes(query) || tags.includes(query);
          const filterMatch =
            activeFilter === "*" ||
            post.classList.contains(activeFilter.slice(1));

          post.style.display = textMatch && filterMatch ? "flex" : "none";
        });
      };

      tagButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          tagButtons.forEach(b => {
            b.classList.remove("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
            b.classList.add("text-text/70", "dark:text-dk-text");
          });
          
          btn.classList.remove("text-text/70", "dark:text-dk-text");
          btn.classList.add("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
          
          activeFilter = btn.dataset.filter;
          applyFilters();
        });
      });

      searchEl.addEventListener("input", applyFilters);

      /* Collapsible Panel */
      const panel = document.getElementById("filters-panel");
      const toggle = document.getElementById("filters-toggle");
      const arrow = document.getElementById("filters-arrow");

      let open = false; 
      panel.style.maxHeight = "0px";

      toggle.addEventListener("click", () => {
        open = !open;
        if (open) {
          panel.style.maxHeight = panel.scrollHeight + "px";
          arrow.style.transform = "rotate(180deg)";
        } else {
          panel.style.maxHeight = "0px";
          arrow.style.transform = "rotate(0deg)";
        }
      });

      // Style initial high-contrast state for 'all' button explicitly on load
      const allBtn = document.querySelector('[data-filter="*"]');
      if(allBtn) {
        allBtn.classList.remove("text-text/70", "dark:text-dk-text");
        allBtn.classList.add("text-secondary", "dark:text-dk-accent", "decoration-secondary", "dark:decoration-dk-accent");
      }

      applyFilters();
    });
  </script>
</BaseLayout>