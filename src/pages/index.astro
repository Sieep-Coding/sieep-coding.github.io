---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import Blog from "../components/post_section/Blog.astro";
import Contact from "../components/contact_section/Contact";
import { Image } from "astro:assets";
const allPosts = await Astro.glob("./posts/*.md");
---

<BaseLayout title="Home">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24 space-y-20">
    <header
      class="flex flex-col sm:flex-row sm:items-center justify-between gap-8"
    >
      <div class="space-y-2 order-2 sm:order-1">
        <div>
          <button
            id="alias-toggle"
            type="button"
            class="flex items-center gap-2 cursor-pointer"
            aria-expanded="false"
          >
            <h1
              class="text-3xl font-bold tracking-tight text-secondary dark:text-dk-accent"
            >
              {info.name}
            </h1>
            <span
              id="alias-caret"
              class="text-lg text-text/50 dark:text-dk-text/50 transition-transform duration-300"
            >
              ^
            </span>
          </button>

          <div
            id="alias-panel"
            class="grid grid-rows-[0fr] overflow-hidden transition-all duration-300"
          >
            <div
              class="overflow-hidden mt-3 flex flex-wrap items-center gap-1 text-sm text-text/80 dark:text-dk-text/80"
            >
              <span class="whitespace-nowrap">alias</span>
              <span class="cursor-help whitespace-nowrap">'sieep'</span>
              <span aria-hidden="true">·</span>

              <a
                href="https://github.com/sieep-coding"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 whitespace-nowrap transition-colors hover:text-secondary dark:hover:text-dk-accent"
              >
                <i class="fab fa-github text-base"></i>
                <span>sieep-coding</span>
              </a>

              <span aria-hidden="true">·</span>

              <a
                href="https://twitch.tv/sieep00"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 whitespace-nowrap transition-colors hover:text-secondary dark:hover:text-dk-accent"
              >
                <i class="fab fa-twitch text-base"></i>
                <span>sieep00</span>
              </a>

              <span aria-hidden="true">·</span>

              <a
                href="https://www.youtube.com/@sieep00"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 whitespace-nowrap transition-colors hover:text-secondary dark:hover:text-dk-accent"
              >
                <i class="fas fa-video text-base"></i>
                <span>@sieep00</span>
              </a>
            </div>
          </div>
        </div>

        <p class="text-text dark:text-dk-text text-lg leading-relaxed pt-1">
          {info.brief_description}
        </p>

        <div class="mt-8 flex flex-wrap gap-x-8 gap-y-4">
          <a
            href="/posts"
            class="inline-flex items-center text-sm font-medium text-secondary dark:text-dk-accent hover:underline underline-offset-4"
          >
            Blog →
          </a>

          <a
            href="/about"
            class="inline-flex items-center text-sm font-medium text-secondary dark:text-dk-accent hover:underline underline-offset-4"
          >
            Nick →
          </a>

          <a
            href="https://luniv.tech/"
            class="inline-flex items-center text-sm font-medium text-secondary dark:text-dk-accent hover:underline underline-offset-4"
          >
            Luniv →
          </a>

          <a
            href="/projects"
            class="inline-flex items-center text-sm font-medium text-secondary dark:text-dk-accent hover:underline underline-offset-4"
          >
            Projects →
          </a>
        </div>
      </div>

      <div class="order-1 sm:order-2 shrink-0">
        <Image
          src={info.picture}
          alt={info.picture_alt}
          width={96}
          height={96}
          class="h-24 w-24 rounded-full object-cover grayscale contrast-115 shadow-sm border border-text/10 dark:border-dk-text/10"
        />
      </div>
    </header>


    <section id="blog">
      <Blog posts={allPosts} />
    </section>

    <hr class="border-text/10 dark:border-dk-text/10" />

    <section id="contact" class="pb-12">
      <div
        class="border border-text/10 dark:border-dk-text/10 bg-secondary/5 dark:bg-dk-secondary/5 rounded-xl p-6"
      >
        <Contact contact={info.contact} size="md" />
      </div>
    </section>
  </main>

  <script>
    const toggle = document.getElementById("alias-toggle");
    const panel = document.getElementById("alias-panel");
    const caret = document.getElementById("alias-caret");

    toggle?.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      panel?.classList.toggle("grid-rows-[0fr]", isOpen);
      panel?.classList.toggle("grid-rows-[1fr]", !isOpen);
      caret?.classList.toggle("rotate-180", !isOpen);
    });
  </script>
</BaseLayout>