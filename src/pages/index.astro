---
import BaseLayout from "../layouts/BaseLayout.astro";
import { info } from "../data/info";
import Blog from "../components/post_section/Blog.astro";
import Contact from "../components/contact_section/Contact";
import { Image } from "astro:assets";

const allPosts = await Astro.glob("./posts/*.md");
---

<BaseLayout title="Home">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24 space-y-20">
    
    <!-- Minimalist Hero Header -->
    <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
      <div class="space-y-3 order-2 sm:order-1">
        <h1 class="text-3xl font-bold tracking-tight text-secondary dark:text-dk-accent">
          Hi, I'm {info.name}
        </h1>
        <p class="text-text dark:text-dk-text text-lg leading-relaxed">
          {info.brief_description}
        </p>
        <p class="text-sm text-text dark:text-dk-text">
          Based in {info.location} — <a href="mailto:nickstambaugh@proton.me" class="text-secondary dark:text-dk-secondary hover:text-secondary/80 dark:hover:text-dk-accent underline decoration-text/30 dark:decoration-dk-text/30 transition-colors">Email me</a>
        </p>
      </div>

      <div class="order-1 sm:order-2 shrink-0">
        <Image
          src={info.picture}
          alt={info.picture_alt}
          width={96}
          height={96}
          class="h-24 w-24 rounded-full object-cover grayscale contrast-115 shadow-sm border border-text/10 dark:border-dk-text/10"
        />
      </div>
    </header>

    <hr class="border-text/10 dark:border-dk-text/10" />

    <!-- Simplified Content Feed -->
    <section id="blog">
      <Blog posts={allPosts} />
    </section>

    <hr class="border-text/10 dark:border-dk-text/10" />

    <!-- Simple Contact Footer Component Integration -->
    <section id="contact" class="pb-12">
      <div class="border border-text/10 dark:border-dk-text/10 bg-secondary/5 dark:bg-dk-secondary/5 rounded-xl p-6">
        <Contact contact={info.contact} size="md" />
      </div>
    </section>

  </main>
</BaseLayout>