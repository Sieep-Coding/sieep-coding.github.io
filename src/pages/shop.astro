---
import ShopLayout from "../layouts/ShopLayout.astro";
import { prints, music } from "../data/shop";

const placeholder =
  "https://placehold.co/800x600/png?text=No+Image";

const formatPrice = (cents: number) =>
  cents === 0 ? "Free" : `$${(cents / 100).toFixed(2)}`;

const typeLabel = (type: string) => {
  if (type === "album") return "Album";
  if (type === "ep") return "EP";
  if (type === "single") return "Single";
  return "Print";
};
---

<ShopLayout
  title="Shop — Nick Stambaugh"
  description="Framed archival prints and music. Each print is hand-signed and ships within a week."
>
  <section class="mb-16">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-lg font-semibold text-[#202020] dark:text-[#7c8fd1]">Framed Prints</h2>
      <div class="flex-1 border-t border-[#202020]/10 dark:border-[#7c8fd1]/20"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {prints.map((product) => (
        <a
          href={`/shop/${product.id}`}
          class="group block border border-[#202020]/10 dark:border-[#7c8fd1]/20 rounded-lg overflow-hidden hover:border-[#202020]/30 dark:hover:border-[#7c8fd1]/50 transition-all duration-200"
        >
          <div class="aspect-[4/3] bg-[#202020]/5 dark:bg-[#7c8fd1]/5 overflow-hidden">
            <img
              src={product.image || placeholder}
              alt={product.title}
              class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
              loading="lazy"
            />
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="font-semibold text-[#202020] dark:text-[#7c8fd1]">
                  {product.title}
                </h3>
                <p class="text-sm text-[#202020]/60 dark:text-[#96a6e2]/60 mt-1">
                  {product.medium}
                </p>
              </div>

              <span class="text-sm font-mono font-semibold text-[#202020] dark:text-[#96a6e2] flex-shrink-0">
                {formatPrice(product.price)}
              </span>
            </div>

            <div class="flex flex-wrap gap-1 mt-3">
              {product.tags?.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/50 dark:text-[#96a6e2]/50">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mb-16">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-lg font-semibold text-[#202020] dark:text-[#7c8fd1]">Music</h2>
      <div class="flex-1 border-t border-[#202020]/10 dark:border-[#7c8fd1]/20"></div>
    </div>

    <div class="flex flex-col gap-4">
      {music.map((product) => (
        <a
          href={`/shop/${product.id}`}
          class="group flex items-center gap-5 border border-[#202020]/10 dark:border-[#7c8fd1]/20 rounded-lg p-4 hover:border-[#202020]/30 dark:hover:border-[#7c8fd1]/50 transition-all duration-200"
        >
          <div class="w-16 h-16 flex-shrink-0 rounded overflow-hidden bg-[#202020]/5 dark:bg-[#7c8fd1]/5">
            <img
              src={product.image || placeholder}
              alt={product.title}
              class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
              loading="lazy"
            />
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-xs tracking-widest uppercase text-[#202020]/40 dark:text-[#96a6e2]/40">
                {typeLabel(product.type)}
              </span>

              {product.releaseYear && (
                <span class="text-xs text-[#202020]/30 dark:text-[#96a6e2]/30">
                  · {product.releaseYear}
                </span>
              )}
            </div>

            <h3 class="font-semibold text-[#202020] dark:text-[#7c8fd1] truncate mt-0.5">
              {product.title}
            </h3>

            <p class="text-sm text-[#202020]/60 dark:text-[#96a6e2]/60 truncate">
              {product.description}
            </p>
          </div>

          <div class="flex-shrink-0 text-right">
            <span class="font-mono text-sm font-semibold text-[#202020] dark:text-[#96a6e2]">
              {formatPrice(product.price)}
            </span>

            {product.tracklist && (
              <p class="text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 mt-1">
                {product.tracklist.length} track
                {product.tracklist.length !== 1 ? "s" : ""}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</ShopLayout>