---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Music — Nick Stambaugh">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24">

    <header class="mb-14">
      <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-2">
        Nick Stambaugh
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-[#202020] dark:text-[#7c8fd1]">
        Music
      </h1>
      <p class="mt-3 text-[#202020]/60 dark:text-[#96a6e2]/60 text-sm leading-relaxed max-w-sm">
        Beats, instrumentals, and production work. Heavily influenced by hip-hop and cinematic game/movie sound design.
      </p>
      
    </header>
    <section class="pb-12">
      <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50">
        Interested in licensing or collaborating? Email me: <a href="mailto:nickstambaugh@proton.me" class="text-[#202020]/70 dark:text-[#96a6e2]/70 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors">nickstambaugh@proton.me</a>.
        </p> 
    </section>
    <!-- Featured track -->
    <section>
      <div class="border border-[#202020]/10 dark:border-[#7c8fd1]/20 rounded-lg overflow-hidden">

        <!-- Waveform / cover art area -->
        <div class="relative bg-[#0d0d0d] aspect-[3/1] flex items-center justify-center overflow-hidden">
          <!-- Ambient animated bars -->
          <div class="waveform-bars" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
          </div>

          <!-- Play button overlay -->
          <button
            id="play-btn"
            class="relative z-10 w-14 h-14 rounded-full border border-white/20 bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-200 group"
            aria-label="Play Normal Life"
          >
            <svg id="icon-play" class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="icon-pause" class="w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>

          <!-- Track label top-left -->
          <div class="absolute top-4 left-4">
            <span class="text-xs tracking-[0.15em] uppercase text-white/30">Single · 2025</span>
          </div>
        </div>

        <!-- Track info -->
        <div class="p-5 flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-[#202020] dark:text-[#7c8fd1]">
              Normal Life
            </h2>
            <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50 mt-1">
              Travis Scott-influenced beat · Val Kilmer vocal sample
            </p>
            <div class="flex flex-wrap gap-1.5 mt-3">
              <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/40 dark:text-[#96a6e2]/40">hip-hop</span>
              <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/40 dark:text-[#96a6e2]/40">atmospheric</span>
              <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/40 dark:text-[#96a6e2]/40">sample-based</span>
            </div>
          </div>

          <div class="flex-shrink-0 flex flex-col items-end gap-2">
            <span class="font-mono text-sm font-semibold text-[#202020] dark:text-[#96a6e2]">Free</span>
            <!-- Progress indicator -->
            <span id="time-display" class="text-xs text-[#202020]/30 dark:text-[#96a6e2]/30 font-mono">0:00</span>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="px-5 pb-5">
          <div
            id="progress-track"
            class="w-full h-0.5 bg-[#202020]/10 dark:bg-[#7c8fd1]/10 rounded-full cursor-pointer relative"
          >
            <div
              id="progress-fill"
              class="h-full bg-[#7c8fd1] dark:bg-[#7c8fd1] rounded-full transition-none"
              style="width: 0%"
            ></div>
          </div>
        </div>
      </div>
    </section>

    <hr class="border-[#202020]/10 dark:border-[#7c8fd1]/10 my-12" />

    <section class="pb-12">
      <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50">
        Interested in licensing or collaborating? Email me: <a href="mailto:nickstambaugh@proton.me" class="text-[#202020]/70 dark:text-[#96a6e2]/70 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors">nickstambaugh@proton.me</a>.
        </p> 
    </section>

  </main>
</BaseLayout>

<style>
  .waveform-bars {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 16px 24px;
  }

  .waveform-bars span {
    flex: 1;
    max-width: 6px;
    background: rgba(124, 143, 209, 0.25);
    border-radius: 2px 2px 0 0;
    animation: pulse-bar 1.4s ease-in-out infinite;
    transform-origin: bottom;
  }

  .waveform-bars span:nth-child(1)  { height: 30%; animation-delay: 0.0s; }
  .waveform-bars span:nth-child(2)  { height: 55%; animation-delay: 0.05s; }
  .waveform-bars span:nth-child(3)  { height: 40%; animation-delay: 0.10s; }
  .waveform-bars span:nth-child(4)  { height: 70%; animation-delay: 0.15s; }
  .waveform-bars span:nth-child(5)  { height: 35%; animation-delay: 0.20s; }
  .waveform-bars span:nth-child(6)  { height: 80%; animation-delay: 0.25s; }
  .waveform-bars span:nth-child(7)  { height: 45%; animation-delay: 0.30s; }
  .waveform-bars span:nth-child(8)  { height: 60%; animation-delay: 0.35s; }
  .waveform-bars span:nth-child(9)  { height: 25%; animation-delay: 0.40s; }
  .waveform-bars span:nth-child(10) { height: 75%; animation-delay: 0.45s; }
  .waveform-bars span:nth-child(11) { height: 50%; animation-delay: 0.50s; }
  .waveform-bars span:nth-child(12) { height: 65%; animation-delay: 0.55s; }
  .waveform-bars span:nth-child(13) { height: 35%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(14) { height: 85%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(15) { height: 40%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(16) { height: 55%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(17) { height: 30%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(18) { height: 70%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(19) { height: 45%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(20) { height: 60%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(21) { height: 25%; animation-delay: 1.00s; }
  .waveform-bars span:nth-child(22) { height: 75%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(23) { height: 50%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(24) { height: 65%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(25) { height: 35%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(26) { height: 85%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(27) { height: 40%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(28) { height: 55%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(29) { height: 30%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(30) { height: 70%; animation-delay: 0.55s; }

  @keyframes pulse-bar {
    0%, 100% { opacity: 0.2; transform: scaleY(0.6); }
    50%       { opacity: 0.5; transform: scaleY(1); }
  }

  /* Bars animate faster when playing */
  .is-playing .waveform-bars span {
    animation-duration: 0.7s;
    background: rgba(124, 143, 209, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .waveform-bars span { animation: none; }
  }
</style>

<script>
  const btn = document.getElementById("play-btn");
  const iconPlay = document.getElementById("icon-play");
  const iconPause = document.getElementById("icon-pause");
  const progressFill = document.getElementById("progress-fill");
  const progressTrack = document.getElementById("progress-track");
  const timeDisplay = document.getElementById("time-display");
  const card = btn?.closest(".border");

  const audio = new Audio("/music-files/normal-life.wav");

  function fmt(s: number) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60).toString().padStart(2, "0");
    return `${m}:${sec}`;
  }

  audio.addEventListener("timeupdate", () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    if (progressFill) progressFill.style.width = `${pct}%`;
    if (timeDisplay) timeDisplay.textContent = fmt(audio.currentTime);
  });

  audio.addEventListener("ended", () => {
    iconPlay?.classList.remove("hidden");
    iconPause?.classList.add("hidden");
    card?.classList.remove("is-playing");
  });

  btn?.addEventListener("click", () => {
    if (audio.paused) {
      audio.play();
      iconPlay?.classList.add("hidden");
      iconPause?.classList.remove("hidden");
      card?.classList.add("is-playing");
    } else {
      audio.pause();
      iconPlay?.classList.remove("hidden");
      iconPause?.classList.add("hidden");
      card?.classList.remove("is-playing");
    }
  });

  progressTrack?.addEventListener("click", (e) => {
    const rect = progressTrack.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  });
</script>