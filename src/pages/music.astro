---
import BaseLayout from "../layouts/BaseLayout.astro";

const tracks = [
  {
    id: "normal-life",
    title: "Normal Life",
    artist: "sieep",
    year: "2025",
    type: "Single",
    description: "Travis Scott-influenced beat · Val Kilmer vocal sample",
    tags: ["hip-hop", "atmospheric", "sample-based"],
    src: "/music-files/normal-life-mix2.wav",
    youtube: "https://www.youtube.com/watch?v=I0BHk5_UDQk",
  },
  {
    id: "be-yourself",
    title: "Be Yourself",
    artist: "sieep",
    year: "2025",
    type: "Single",
    description: "Bruce Lee vocal sample · chopped wet guitar · DJ scratches",
    tags: ["hip-hop", "sample-only"],
    src: "/music-files/sample-only-drums-2.wav",
    youtube: "https://www.youtube.com/watch?v=-wRETGIhiKI",
  },
];
---

<BaseLayout title="Music — Nick Stambaugh">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24">

    <header class="mb-14">
      <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-2">
        Nick Stambaugh
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-[#202020] dark:text-[#7c8fd1]">
        Music
      </h1>
      <p class="mt-3 text-[#202020]/90 dark:text-[#96a6e2]/90 text-sm leading-relaxed max-w-sm">
        Beats, instrumentals, and production work. Heavily influenced by hip-hop
        and cinematic game/movie sound design.
      </p>
      <p class="mt-3 text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 leading-relaxed max-w-sm">
        <strong class="font-semibold text-[#202020]/50 dark:text-[#96a6e2]/50">Note:</strong>
        Mastering may not be final, volume may be too loud, and some tracks are rough drafts.
      </p>
    </header>

    <!-- ─── Track list ─────────────────────────────────────────── -->
    <section aria-label="Tracks">
      <ul class="flex flex-col gap-4">
        {tracks.map((track) => (
          <li
            class="track-card border border-[#202020]/10 dark:border-[#7c8fd1]/20 rounded-lg overflow-hidden"
            data-src={track.src}
            data-id={track.id}
          >
            <!-- Waveform bar -->
            <div class="waveform-area relative bg-[#0d0d0d] h-16 flex items-center px-5 gap-4 select-none overflow-hidden">
              <div class="waveform-bars" aria-hidden="true">
                {Array.from({ length: 40 }).map(() => <span />)}
              </div>

              <!-- Play / Pause -->
              <button
                class="play-btn relative z-10 w-9 h-9 rounded-full border border-white/20 bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-200 flex-shrink-0"
                aria-label={`Play ${track.title}`}
              >
                <svg class="icon-play w-3.5 h-3.5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <svg class="icon-pause w-3.5 h-3.5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                </svg>
              </button>

              <!-- Progress bar (inline in waveform) -->
              <div
                class="progress-track relative z-10 flex-1 h-1 bg-white/10 rounded-full cursor-pointer group"
                role="slider"
                aria-label="Seek"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                tabindex="0"
              >
                <div class="progress-fill h-full bg-[#7c8fd1] rounded-full pointer-events-none" style="width:0%"></div>
                <div class="progress-thumb absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-[#7c8fd1] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" style="left:0%"></div>
              </div>

              <!-- Time -->
              <span class="time-display relative z-10 text-[10px] font-mono tabular-nums text-white/30 flex-shrink-0 hidden sm:block">
                0:00 / —:——
              </span>
            </div>

            <!-- Info row -->
            <div class="px-5 py-4 flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[#202020] dark:text-[#7c8fd1] leading-snug truncate">
                  {track.title}
                  <span class="font-normal text-[#202020]/40 dark:text-[#96a6e2]/40"> — {track.artist}</span>
                </p>
                <p class="text-xs text-[#202020]/50 dark:text-[#96a6e2]/50 mt-1 truncate">
                  {track.description}
                </p>
                <div class="flex flex-wrap gap-1.5 mt-2.5">
                  {track.tags.map((tag) => (
                    <span class="text-[10px] px-1.5 py-0.5 rounded border border-[#202020]/12 dark:border-[#7c8fd1]/20 text-[#202020]/35 dark:text-[#96a6e2]/35">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Right column: year + YouTube + licensing -->
              <div class="flex-shrink-0 flex flex-col items-end gap-2 pt-0.5">
                <span class="font-mono text-[10px] text-[#202020]/30 dark:text-[#96a6e2]/30">
                  {track.type} · {track.year}
                </span>
                {track.youtube && (
                  <a
                    href={track.youtube}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Watch ${track.title} on YouTube`}
                    class="flex items-center gap-1.5 text-[#202020]/30 dark:text-[#96a6e2]/30 hover:text-[#202020]/60 dark:hover:text-[#96a6e2]/60 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
                    </svg>
                    <span class="text-[10px] tracking-widest uppercase font-mono">YouTube</span>
                  </a>
                )}
                <span class="font-mono text-[10px] text-[#202020]/30 dark:text-[#96a6e2]/30 whitespace-nowrap">
                  Email for licensing
                </span>
              </div>
            </div>

            <!-- Volume row -->
            <div class="px-5 pb-4 flex items-center gap-3">
              <button
                class="mute-btn text-[#202020]/30 dark:text-[#96a6e2]/30 hover:text-[#202020]/60 dark:hover:text-[#96a6e2]/60 transition-colors flex-shrink-0"
                aria-label="Toggle mute"
              >
                <svg class="icon-vol w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
                </svg>
                <svg class="icon-mute w-3.5 h-3.5 hidden" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                </svg>
              </button>
              <input
                class="vol-slider volume-range w-20 h-1 cursor-pointer"
                type="range" min="0" max="1" step="0.02" value="1"
                aria-label="Volume"
              />
              <span class="hidden sm:block text-[10px] tracking-widest uppercase text-white/10 font-mono ml-auto">
                Space to play
              </span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <hr class="border-[#202020]/10 dark:border-[#7c8fd1]/10 my-12" />

    <footer class="pb-12">
      <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50">
        Interested in licensing or collaborating? Email me:{" "}
        <a
          href="mailto:nickstambaugh@proton.me"
          class="text-[#202020]/70 dark:text-[#96a6e2]/70 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors"
        >
          nickstambaugh@proton.me
        </a>.
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  .waveform-bars {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 2px;
    padding: 8px 16px;
  }

  .waveform-bars span {
    flex: 1;
    max-width: 5px;
    background: rgba(124, 143, 209, 0.2);
    border-radius: 2px 2px 0 0;
    animation: pulse-bar 1.4s ease-in-out infinite;
    transform-origin: bottom;
  }

  /* Heights + delays for 40 bars */
  .waveform-bars span:nth-child(1)  { height: 30%; animation-delay: 0.00s; }
  .waveform-bars span:nth-child(2)  { height: 55%; animation-delay: 0.05s; }
  .waveform-bars span:nth-child(3)  { height: 40%; animation-delay: 0.10s; }
  .waveform-bars span:nth-child(4)  { height: 70%; animation-delay: 0.15s; }
  .waveform-bars span:nth-child(5)  { height: 35%; animation-delay: 0.20s; }
  .waveform-bars span:nth-child(6)  { height: 80%; animation-delay: 0.25s; }
  .waveform-bars span:nth-child(7)  { height: 45%; animation-delay: 0.30s; }
  .waveform-bars span:nth-child(8)  { height: 60%; animation-delay: 0.35s; }
  .waveform-bars span:nth-child(9)  { height: 25%; animation-delay: 0.40s; }
  .waveform-bars span:nth-child(10) { height: 75%; animation-delay: 0.45s; }
  .waveform-bars span:nth-child(11) { height: 50%; animation-delay: 0.50s; }
  .waveform-bars span:nth-child(12) { height: 65%; animation-delay: 0.55s; }
  .waveform-bars span:nth-child(13) { height: 35%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(14) { height: 85%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(15) { height: 40%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(16) { height: 55%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(17) { height: 30%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(18) { height: 70%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(19) { height: 45%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(20) { height: 60%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(21) { height: 80%; animation-delay: 1.00s; }
  .waveform-bars span:nth-child(22) { height: 35%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(23) { height: 55%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(24) { height: 25%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(25) { height: 65%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(26) { height: 40%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(27) { height: 75%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(28) { height: 50%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(29) { height: 85%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(30) { height: 30%; animation-delay: 0.55s; }
  .waveform-bars span:nth-child(31) { height: 60%; animation-delay: 0.50s; }
  .waveform-bars span:nth-child(32) { height: 45%; animation-delay: 0.45s; }
  .waveform-bars span:nth-child(33) { height: 70%; animation-delay: 0.40s; }
  .waveform-bars span:nth-child(34) { height: 35%; animation-delay: 0.35s; }
  .waveform-bars span:nth-child(35) { height: 55%; animation-delay: 0.30s; }
  .waveform-bars span:nth-child(36) { height: 25%; animation-delay: 0.25s; }
  .waveform-bars span:nth-child(37) { height: 65%; animation-delay: 0.20s; }
  .waveform-bars span:nth-child(38) { height: 40%; animation-delay: 0.15s; }
  .waveform-bars span:nth-child(39) { height: 50%; animation-delay: 0.10s; }
  .waveform-bars span:nth-child(40) { height: 30%; animation-delay: 0.05s; }

  @keyframes pulse-bar {
    0%, 100% { opacity: 0.15; transform: scaleY(0.5); }
    50%       { opacity: 0.4;  transform: scaleY(1);   }
  }

  .is-playing .waveform-bars span {
    animation-duration: 0.7s;
    background: rgba(124, 143, 209, 0.45);
  }

  .volume-range {
    -webkit-appearance: none;
    appearance: none;
    background: rgba(124, 143, 209, 0.15);
    border-radius: 999px;
    height: 4px;
    outline: none;
  }
  .volume-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #7c8fd1;
    cursor: pointer;
  }
  .volume-range::-moz-range-thumb {
    width: 10px;
    height: 10px;
    border: none;
    border-radius: 50%;
    background: #7c8fd1;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .waveform-bars span { animation: none; }
  }
</style>

<script>
  // Track the currently active Audio instance so only one plays at a time
  let activeAudio: HTMLAudioElement | null = null;

  function fmt(s: number): string {
    const m   = Math.floor(s / 60);
    const sec = Math.floor(s % 60).toString().padStart(2, "0");
    return `${m}:${sec}`;
  }

  document.querySelectorAll<HTMLElement>(".track-card").forEach((card) => {
    const src         = card.dataset.src!;
    const audio       = new Audio(src);
    audio.preload     = "metadata";

    const playBtn       = card.querySelector<HTMLButtonElement>(".play-btn")!;
    const iconPlay      = card.querySelector<SVGElement>(".icon-play")!;
    const iconPause     = card.querySelector<SVGElement>(".icon-pause")!;
    const progressTrack = card.querySelector<HTMLElement>(".progress-track")!;
    const progressFill  = card.querySelector<HTMLElement>(".progress-fill")!;
    const progressThumb = card.querySelector<HTMLElement>(".progress-thumb")!;
    const timeDisplay   = card.querySelector<HTMLElement>(".time-display")!;
    const muteBtn       = card.querySelector<HTMLButtonElement>(".mute-btn")!;
    const iconVol       = card.querySelector<SVGElement>(".icon-vol")!;
    const iconMute      = card.querySelector<SVGElement>(".icon-mute")!;
    const volSlider     = card.querySelector<HTMLInputElement>(".vol-slider")!;

    function setPlaying(playing: boolean) {
      iconPlay.classList.toggle("hidden", playing);
      iconPause.classList.toggle("hidden", !playing);
      card.classList.toggle("is-playing", playing);
    }

    function setProgress(pct: number) {
      progressFill.style.width = `${pct}%`;
      progressThumb.style.left = `${pct}%`;
      progressTrack.setAttribute("aria-valuenow", String(Math.round(pct)));
    }

    function syncMuteIcon() {
      const muted = audio.muted || audio.volume === 0;
      iconVol.classList.toggle("hidden", muted);
      iconMute.classList.toggle("hidden", !muted);
    }

    // Playback
    playBtn.addEventListener("click", () => {
      if (!audio.paused) {
        audio.pause();
        return;
      }
      // Pause whatever else is playing
      if (activeAudio && activeAudio !== audio) activeAudio.pause();
      activeAudio = audio;
      audio.play();
    });

    audio.addEventListener("play",  () => setPlaying(true));
    audio.addEventListener("pause", () => setPlaying(false));
    audio.addEventListener("ended", () => {
      setPlaying(false);
      setProgress(0);
      if (timeDisplay) timeDisplay.textContent = "0:00 / " + (audio.duration ? fmt(audio.duration) : "—:——");
    });

    audio.addEventListener("timeupdate", () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      setProgress(pct);
      if (timeDisplay) timeDisplay.textContent = fmt(audio.currentTime) + " / " + fmt(audio.duration);
    });

    audio.addEventListener("loadedmetadata", () => {
      if (timeDisplay) timeDisplay.textContent = "0:00 / " + fmt(audio.duration);
    });

    // Seek
    function seekTo(e: MouseEvent | TouchEvent) {
      const rect    = progressTrack.getBoundingClientRect();
      const clientX = e instanceof TouchEvent ? e.touches[0].clientX : e.clientX;
      const pct     = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      if (audio.duration) audio.currentTime = pct * audio.duration;
    }

    let seeking = false;
    progressTrack.addEventListener("mousedown", (e) => { seeking = true; seekTo(e); });
    window.addEventListener("mousemove",        (e) => { if (seeking) seekTo(e); });
    window.addEventListener("mouseup",          ()  => { seeking = false; });
    progressTrack.addEventListener("touchstart", seekTo, { passive: true });
    progressTrack.addEventListener("touchmove",  seekTo, { passive: true });

    progressTrack.addEventListener("keydown", (e) => {
      if (!audio.duration) return;
      const step = audio.duration * 0.02;
      if (e.key === "ArrowRight") audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
      if (e.key === "ArrowLeft")  audio.currentTime = Math.max(0, audio.currentTime - step);
    });

    // Volume
    volSlider.addEventListener("input", () => {
      audio.volume = parseFloat(volSlider.value);
      audio.muted  = audio.volume === 0;
      syncMuteIcon();
    });

    muteBtn.addEventListener("click", () => {
      audio.muted = !audio.muted;
      syncMuteIcon();
    });
  });

  // Space bar plays/pauses whichever card is active
  document.addEventListener("keydown", (e) => {
    if (e.code !== "Space") return;
    const tag = (e.target as HTMLElement).tagName;
    if (tag === "INPUT" || tag === "TEXTAREA" || tag === "BUTTON") return;
    e.preventDefault();
    if (!activeAudio) return;
    activeAudio.paused ? activeAudio.play() : activeAudio.pause();
  });
</script>