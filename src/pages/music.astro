---
import BaseLayout from "../layouts/BaseLayout.astro";

const tracks = [
  {
    id: "normal-life",
    title: "Normal Life",
    artist: "sieep",
    year: "2025",
    type: "Single",
    description: "Travis Scott-influenced beat · Val Kilmer vocal sample",
    tags: ["hip-hop", "atmospheric", "sample-based"],
    src: "/music-files/normal-life-mix2.wav",
    featured: true,
  },
  // Add more tracks here:
  // { id: "track-2", title: "…", artist: "sieep", year: "2025", type: "Single", description: "…", tags: ["…"], src: "/music-files/…", featured: false },
];

const featuredTrack = tracks.find((t) => t.featured)!;
const catalogTracks = tracks.filter((t) => !t.featured);
---

<BaseLayout title="Music — Nick Stambaugh">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24">

    <!-- Page header -->
    <header class="mb-14">
      <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-2">
        Nick Stambaugh
      </p>
      <h1 class="text-3xl font-bold tracking-tight text-[#202020] dark:text-[#7c8fd1]">
        Music
      </h1>
      <p class="mt-3 text-[#202020]/90 dark:text-[#96a6e2]/90 text-sm leading-relaxed max-w-sm">
        Beats, instrumentals, and production work. Heavily influenced by hip-hop
        and cinematic game/movie sound design.
      </p>
      <p class="mt-3 text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 leading-relaxed max-w-sm">
        <strong class="font-semibold text-[#202020]/50 dark:text-[#96a6e2]/50">Note:</strong>
        Mastering may not be final, volume may be too loud, and some tracks are rough drafts.
      </p>
    </header>

    <!-- ─── Featured track ─────────────────────────────────────── -->
    <section aria-label="Featured track">
      <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/30 dark:text-[#96a6e2]/30 mb-4">
        Featured
      </p>

      <div
        id="featured-card"
        class="border border-[#202020]/10 dark:border-[#7c8fd1]/20 rounded-lg overflow-hidden"
        data-src={featuredTrack.src}
      >
        <!-- Waveform / cover art -->
        <div class="relative bg-[#0d0d0d] aspect-[3/1] flex items-center justify-center overflow-hidden select-none">
          <div class="waveform-bars" aria-hidden="true">
            {Array.from({ length: 30 }).map((_, i) => <span />)}
          </div>

          <!-- Play / Pause -->
          <button
            id="play-btn"
            class="relative z-10 w-14 h-14 rounded-full border border-white/20 bg-white/10 backdrop-blur-sm flex items-center justify-center hover:bg-white/20 transition-all duration-200"
            aria-label={`Play ${featuredTrack.title}`}
          >
            <svg id="icon-play" class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="icon-pause" class="w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>

          <!-- Track label -->
          <div class="absolute top-4 left-4">
            <span class="text-xs tracking-[0.15em] uppercase text-white/30">
              {featuredTrack.type} · {featuredTrack.year}
            </span>
          </div>

          <!-- Keyboard hint -->
          <div class="absolute bottom-3 right-4 hidden sm:block">
            <span class="text-[10px] tracking-widest uppercase text-white/15 font-mono">Space to play</span>
          </div>
        </div>

        <!-- Track info row -->
        <div class="px-5 pt-5 flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-[#202020] dark:text-[#7c8fd1] leading-snug">
              {featuredTrack.title}
              <span class="font-normal text-[#202020]/40 dark:text-[#96a6e2]/40"> — {featuredTrack.artist}</span>
            </h2>
            <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50 mt-1">
              {featuredTrack.description}
            </p>
            <div class="flex flex-wrap gap-1.5 mt-3">
              {featuredTrack.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/40 dark:text-[#96a6e2]/40">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <div class="flex-shrink-0 flex flex-col items-end gap-2 pt-0.5">
            <span class="font-mono text-xs font-semibold text-[#202020]/50 dark:text-[#96a6e2]/50 whitespace-nowrap">
              Email for licensing
            </span>
            <span id="time-display" class="text-xs text-[#202020]/30 dark:text-[#96a6e2]/30 font-mono tabular-nums">
              0:00 / —:——
            </span>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="px-5 pt-4">
          <div
            id="progress-track"
            role="slider"
            aria-label="Seek"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            tabindex="0"
            class="w-full h-1 bg-[#202020]/10 dark:bg-[#7c8fd1]/10 rounded-full cursor-pointer relative group"
          >
            <div
              id="progress-fill"
              class="h-full bg-[#7c8fd1] rounded-full pointer-events-none"
              style="width: 0%"
            ></div>
            <!-- Scrub thumb -->
            <div
              id="progress-thumb"
              class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-[#7c8fd1] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
              style="left: 0%"
            ></div>
          </div>
        </div>

        <!-- Volume row -->
        <div class="px-5 py-4 flex items-center gap-3">
          <button
            id="mute-btn"
            aria-label="Toggle mute"
            class="text-[#202020]/30 dark:text-[#96a6e2]/30 hover:text-[#202020]/60 dark:hover:text-[#96a6e2]/60 transition-colors flex-shrink-0"
          >
            <!-- Speaker icon (unmuted) -->
            <svg id="icon-vol" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
            </svg>
            <!-- Muted icon -->
            <svg id="icon-mute" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
            </svg>
          </button>

          <input
            id="volume-slider"
            type="range"
            min="0"
            max="1"
            step="0.02"
            value="1"
            aria-label="Volume"
            class="volume-range w-24 h-1 accent-[#7c8fd1] cursor-pointer"
          />
        </div>
      </div>
    </section>

    <!-- ─── Catalog ────────────────────────────────────────────── -->
    {catalogTracks.length > 0 && (
      <section class="mt-14" aria-label="Track catalog">
        <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/30 dark:text-[#96a6e2]/30 mb-5">
          All tracks
        </p>
        <ul class="divide-y divide-[#202020]/8 dark:divide-[#7c8fd1]/10">
          {catalogTracks.map((track, i) => (
            <li>
              <button
                class="catalog-track w-full text-left py-4 flex items-center gap-4 group"
                data-src={track.src}
                data-title={track.title}
                data-artist={track.artist}
                aria-label={`Play ${track.title}`}
              >
                <span class="w-5 text-center font-mono text-xs text-[#202020]/30 dark:text-[#96a6e2]/30 group-hover:hidden flex-shrink-0">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="w-5 hidden group-hover:flex items-center justify-center flex-shrink-0 text-[#7c8fd1]">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-[#202020] dark:text-[#7c8fd1] truncate">
                    {track.title}
                    <span class="font-normal text-[#202020]/40 dark:text-[#96a6e2]/40"> — {track.artist}</span>
                  </p>
                  <p class="text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 mt-0.5 truncate">
                    {track.description}
                  </p>
                </div>
                <div class="hidden sm:flex items-center gap-2 flex-shrink-0">
                  {track.tags.slice(0, 2).map((tag) => (
                    <span class="text-[10px] px-1.5 py-0.5 rounded border border-[#202020]/10 dark:border-[#7c8fd1]/15 text-[#202020]/35 dark:text-[#96a6e2]/35">
                      {tag}
                    </span>
                  ))}
                  <span class="text-xs font-mono text-[#202020]/25 dark:text-[#96a6e2]/25 ml-1">{track.year}</span>
                </div>
              </button>
            </li>
          ))}
        </ul>
      </section>
    )}

    <hr class="border-[#202020]/10 dark:border-[#7c8fd1]/10 my-12" />

    <footer class="pb-12">
      <p class="text-sm text-[#202020]/50 dark:text-[#96a6e2]/50">
        Interested in licensing or collaborating? Email me:{" "}
        <a
          href="mailto:nickstambaugh@proton.me"
          class="text-[#202020]/70 dark:text-[#96a6e2]/70 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors"
        >
          nickstambaugh@proton.me
        </a>.
      </p>
    </footer>
  </main>
</BaseLayout>

<!-- ─────────────────────────────── styles ──────────────────────── -->
<style>
  /* Waveform bars */
  .waveform-bars {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 16px 24px;
  }

  .waveform-bars span {
    flex: 1;
    max-width: 6px;
    background: rgba(124, 143, 209, 0.25);
    border-radius: 2px 2px 0 0;
    animation: pulse-bar 1.4s ease-in-out infinite;
    transform-origin: bottom;
  }

  /* Heights + delays for 30 bars */
  .waveform-bars span:nth-child(1)  { height: 30%; animation-delay: 0.00s; }
  .waveform-bars span:nth-child(2)  { height: 55%; animation-delay: 0.05s; }
  .waveform-bars span:nth-child(3)  { height: 40%; animation-delay: 0.10s; }
  .waveform-bars span:nth-child(4)  { height: 70%; animation-delay: 0.15s; }
  .waveform-bars span:nth-child(5)  { height: 35%; animation-delay: 0.20s; }
  .waveform-bars span:nth-child(6)  { height: 80%; animation-delay: 0.25s; }
  .waveform-bars span:nth-child(7)  { height: 45%; animation-delay: 0.30s; }
  .waveform-bars span:nth-child(8)  { height: 60%; animation-delay: 0.35s; }
  .waveform-bars span:nth-child(9)  { height: 25%; animation-delay: 0.40s; }
  .waveform-bars span:nth-child(10) { height: 75%; animation-delay: 0.45s; }
  .waveform-bars span:nth-child(11) { height: 50%; animation-delay: 0.50s; }
  .waveform-bars span:nth-child(12) { height: 65%; animation-delay: 0.55s; }
  .waveform-bars span:nth-child(13) { height: 35%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(14) { height: 85%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(15) { height: 40%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(16) { height: 55%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(17) { height: 30%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(18) { height: 70%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(19) { height: 45%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(20) { height: 60%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(21) { height: 25%; animation-delay: 1.00s; }
  .waveform-bars span:nth-child(22) { height: 75%; animation-delay: 0.95s; }
  .waveform-bars span:nth-child(23) { height: 50%; animation-delay: 0.90s; }
  .waveform-bars span:nth-child(24) { height: 65%; animation-delay: 0.85s; }
  .waveform-bars span:nth-child(25) { height: 35%; animation-delay: 0.80s; }
  .waveform-bars span:nth-child(26) { height: 85%; animation-delay: 0.75s; }
  .waveform-bars span:nth-child(27) { height: 40%; animation-delay: 0.70s; }
  .waveform-bars span:nth-child(28) { height: 55%; animation-delay: 0.65s; }
  .waveform-bars span:nth-child(29) { height: 30%; animation-delay: 0.60s; }
  .waveform-bars span:nth-child(30) { height: 70%; animation-delay: 0.55s; }

  @keyframes pulse-bar {
    0%, 100% { opacity: 0.2; transform: scaleY(0.6); }
    50%       { opacity: 0.5; transform: scaleY(1);   }
  }

  .is-playing .waveform-bars span {
    animation-duration: 0.7s;
    background: rgba(124, 143, 209, 0.5);
  }

  /* Volume slider — cross-browser */
  .volume-range {
    -webkit-appearance: none;
    appearance: none;
    background: rgba(124, 143, 209, 0.15);
    border-radius: 999px;
    height: 4px;
    outline: none;
  }
  .volume-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #7c8fd1;
    cursor: pointer;
  }
  .volume-range::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border: none;
    border-radius: 50%;
    background: #7c8fd1;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .waveform-bars span { animation: none; }
  }
</style>

<!-- ─────────────────────────────── script ──────────────────────── -->
<script>
  /* ── elements ─────────────────────────────────────── */
  const card          = document.getElementById("featured-card")!;
  const btn           = document.getElementById("play-btn")!;
  const iconPlay      = document.getElementById("icon-play")!;
  const iconPause     = document.getElementById("icon-pause")!;
  const progressFill  = document.getElementById("progress-fill")!;
  const progressThumb = document.getElementById("progress-thumb")!;
  const progressTrack = document.getElementById("progress-track")!;
  const timeDisplay   = document.getElementById("time-display")!;
  const muteBtn       = document.getElementById("mute-btn")!;
  const iconVol       = document.getElementById("icon-vol")!;
  const iconMute      = document.getElementById("icon-mute")!;
  const volSlider     = document.getElementById("volume-slider") as HTMLInputElement;

  /* ── audio ────────────────────────────────────────── */
  const src   = card.dataset.src!;
  const audio = new Audio(src);
  audio.preload = "metadata";

  /* ── helpers ──────────────────────────────────────── */
  function fmt(s: number): string {
    const m   = Math.floor(s / 60);
    const sec = Math.floor(s % 60).toString().padStart(2, "0");
    return `${m}:${sec}`;
  }

  function setPlaying(playing: boolean) {
    iconPlay.classList.toggle("hidden",  playing);
    iconPause.classList.toggle("hidden", !playing);
    card.classList.toggle("is-playing",  playing);
    btn.setAttribute("aria-label", playing ? "Pause" : "Play Normal Life");
  }

  function setProgress(pct: number) {
    progressFill.style.width           = `${pct}%`;
    progressThumb.style.left           = `${pct}%`;
    progressTrack.setAttribute("aria-valuenow", String(Math.round(pct)));
  }

  /* ── playback ─────────────────────────────────────── */
  btn.addEventListener("click", () => {
    audio.paused ? audio.play() : audio.pause();
  });

  audio.addEventListener("play",  () => setPlaying(true));
  audio.addEventListener("pause", () => setPlaying(false));
  audio.addEventListener("ended", () => {
    setPlaying(false);
    setProgress(0);
    timeDisplay.textContent = "0:00 / " + (audio.duration ? fmt(audio.duration) : "—:——");
  });

  audio.addEventListener("timeupdate", () => {
    if (!audio.duration) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    setProgress(pct);
    timeDisplay.textContent = fmt(audio.currentTime) + " / " + fmt(audio.duration);
  });

  audio.addEventListener("loadedmetadata", () => {
    timeDisplay.textContent = "0:00 / " + fmt(audio.duration);
  });

  /* ── seek ─────────────────────────────────────────── */
  function seekTo(e: MouseEvent | TouchEvent) {
    const rect = progressTrack.getBoundingClientRect();
    const clientX = (e instanceof TouchEvent) ? e.touches[0].clientX : e.clientX;
    const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    if (audio.duration) audio.currentTime = pct * audio.duration;
  }

  let seeking = false;
  progressTrack.addEventListener("mousedown", (e) => { seeking = true; seekTo(e); });
  window.addEventListener("mousemove",        (e) => { if (seeking) seekTo(e); });
  window.addEventListener("mouseup",          ()  => { seeking = false; });
  progressTrack.addEventListener("touchstart", seekTo, { passive: true });
  progressTrack.addEventListener("touchmove",  seekTo, { passive: true });

  /* Arrow-key seek on the slider */
  progressTrack.addEventListener("keydown", (e) => {
    if (!audio.duration) return;
    const step = audio.duration * 0.02;
    if (e.key === "ArrowRight") audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
    if (e.key === "ArrowLeft")  audio.currentTime = Math.max(0, audio.currentTime - step);
  });

  /* ── volume ───────────────────────────────────────── */
  volSlider.addEventListener("input", () => {
    audio.volume = parseFloat(volSlider.value);
    audio.muted  = audio.volume === 0;
    syncMuteIcon();
  });

  muteBtn.addEventListener("click", () => {
    audio.muted = !audio.muted;
    syncMuteIcon();
  });

  function syncMuteIcon() {
    const muted = audio.muted || audio.volume === 0;
    iconVol.classList.toggle("hidden",  muted);
    iconMute.classList.toggle("hidden", !muted);
  }

  /* ── keyboard shortcut (Space) ────────────────────── */
  document.addEventListener("keydown", (e) => {
    if (e.code !== "Space") return;
    const tag = (e.target as HTMLElement).tagName;
    if (tag === "INPUT" || tag === "TEXTAREA" || tag === "BUTTON") return;
    e.preventDefault();
    audio.paused ? audio.play() : audio.pause();
  });

  /* ── catalog tracks (swap into featured player) ───── */
  document.querySelectorAll<HTMLButtonElement>(".catalog-track").forEach((row) => {
    row.addEventListener("click", () => {
      const newSrc = row.dataset.src!;
      if (audio.src !== newSrc) {
        audio.pause();
        audio.src = newSrc;
        setProgress(0);
        timeDisplay.textContent = "0:00 / —:——";
        audio.load();
      }
      audio.play();
    });
  });
</script>