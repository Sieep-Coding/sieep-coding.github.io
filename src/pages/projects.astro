---
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredCases = [
  {
    name: "WMS-CRM Integration API",
    description:
      "A robust middleware solution linking a legacy WMS AX system to a modern SaaS CRM, automating real-time inventory and customer data synchronization.",
    tags: ["Middleware", "API Development", "Integration"],
    accent: "#F97316",
    liveLink: "/contact",
    link: "https://www.luniv.tech/case-study/wms-crm-integration",
    outcome:
      "Eliminated manual data entry and stock discrepancies by establishing a reliable, automated sync pipeline.",
    image:
      "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1600&q=80",
  },
  {
    name: "BOLD Talks",
    description:
      "An intimate speaker series bringing together curious minds in Grand Rapids for evenings of thoughtful dialogue with authors, academics, and thinkers.",
    tags: ["Events", "Community", "Web Design"],
    accent: "#F59E0B",
    liveLink: "https://bold-talks.com",
    link: "https://www.luniv.tech/case-study/bold-talks",
    outcome:
      "Turned a cigar bar conversation series into a discoverable, RSVP-ready digital presence.",
    image:
      "https://images.unsplash.com/photo-1505373877841-8d25f7d46678?auto=format&fit=crop&w=1600&q=80",
  },
  {
    name: "MPD Welding GR Inc.",
    description:
      "A lead-generation web presence for a Grand Rapids precision welding and steel treating shop — built to capture quotes and job applications around the clock.",
    tags: ["Industrial", "Web Design", "Lead Generation"],
    accent: "#EF4444",
    liveLink: "https://www.mpdwelding.com",
    link: "https://www.luniv.tech/case-study/mpd-welding",
    outcome:
      "Turned a legacy industrial site into a 24/7 quote intake and recruiting machine.",
    image:
      "https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=1600&q=80",
  },
  {
    name: "Performance Management Platform",
    description:
      "An enterprise performance management platform built to streamline annual reviews, competency assessments, goal tracking, and executive reporting across the organization.",
    tags: ["Enterprise Software", "HR Tech", "Internal Tools"],
    accent: "#3B82F6",
    liveLink: "/contact",
    link: "https://www.luniv.tech/case-study/performance-management-platform",
    outcome:
      "Replaced spreadsheet-driven review cycles with a configurable workflow platform managed entirely by HR administrators.",
    image:
      "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1600&q=80",
  },
  {
    name: "Document Management Software",
    description:
      "A centralized document management system providing version control, approval workflows, metadata indexing, and enterprise search.",
    tags: ["Enterprise Software", "Document Management", "Internal Tools"],
    accent: "#A855F7",
    liveLink: "/contact",
    link: "https://www.luniv.tech/case-study/document-management-software",
    outcome:
      "Unified document storage and governance while improving searchability and compliance.",
    image:
      "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1600&q=80",
  },
];

const openSourceProjects = [
  {
    title: "Spark",
    year: "2025",
    description: "A blazing-fast GUI tool for managing relationship and project data.",
    link: "https://github.com/Sieep-Coding/spark",
    tech: ["Python", "tkinter"],
  },
  {
    title: "Lua Testing Framework",
    year: "2024",
    description: "A single-file, minimal Lua testing framework. No dependencies.",
    link: "https://github.com/Sieep-Coding/check-your-lua",
    tech: ["Lua"],
  },
  {
    title: "Laptop CLI",
    year: "2024",
    description: "Go CLI tool used to manage donated device inventory for my non-profit.",
    link: "https://github.com/Sieep-Coding/laptop-cli",
    tech: ["Go"],
  },
  {
    title: "Chat Server in Go",
    year: "2024",
    description: "A single-file TCP chat server written in Go.",
    link: "https://github.com/Sieep-Coding/chatserver",
    tech: ["Go"],
  },
  {
    title: "Go + HTMX + Alpine.js",
    year: "2024",
    description: "A simple todo app in HTMX, Alpine.js, and Go.",
    link: "https://github.com/Sieep-Coding/todo-htmx-alpine-go",
    tech: ["Go", "HTMX", "Alpine.js"],
  },
  {
    title: "NoteZone",
    year: "2024",
    description: "A feature-rich note-taking app built with Electron.",
    link: "https://github.com/Sieep-Coding/notezone",
    tech: ["Electron", "Node.js"],
  },
  {
    title: "Web Crawler",
    year: "2024",
    description: "A fast web crawler with customizable depth and domain parameters.",
    link: "https://github.com/Sieep-Coding/web-crawler",
    tech: ["Go"],
  },
  {
    title: "Snow Simulation",
    year: "2024",
    description: "A physics-based snow particle simulation built with C and raylib.",
    link: "https://github.com/Sieep-Coding/snow-simulation",
    tech: ["C", "raylib"],
  },
];
---

<BaseLayout title="Projects — Nick Stambaugh">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&display=swap');

    .projects-root {
      --serif: "DM Serif Display", Georgia, serif;
      --mono: "DM Mono", ui-monospace, monospace;
      --rule: rgba(0, 0, 0, 0.12);
      --muted: #555;
      --hover-bg: rgba(0, 0, 0, 0.03);
      --button-bg: rgb(42, 147, 161);
    }

    :global(.dark) .projects-root {
      --rule: rgba(255, 255, 255, 0.1);
      --muted: #999;
      --hover-bg: rgba(255, 255, 255, 0.04);
    }

    /* ── MASTHEAD ── */
    .masthead {
      padding: 5rem 0 3.5rem;
      margin-bottom: 0;
    }

    .masthead-eyebrow {
      font-family: var(--mono);
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .masthead-headline {
      font-family: var(--serif);
      font-size: clamp(3.2rem, 8vw, 6.5rem);
      line-height: 0.96;
      letter-spacing: -0.02em;
      max-width: 12ch;
      margin-bottom: 2.5rem;
    }

    .masthead-headline em {
      font-style: italic;
      color: var(--muted);
    }

    .masthead-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem 2.5rem;
      padding-top: 2rem;
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--muted);
      letter-spacing: 0.06em;
    }

    .masthead-meta a {
      color: inherit;
      text-decoration: none;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-family: var(--mono);
      font-size: 0.8rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      padding-top: 1.1rem;
      margin-bottom: 3rem;
    }

    /* ── CASE STUDIES ── */
    .cases-section {
      padding: 5rem 0;
    }

    .case-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--rule);
      min-height: 440px;
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
    }

    .case-row:last-child {
      border-bottom: 1px solid var(--rule);
    }

    .case-row:hover {
      background: var(--hover-bg);
    }

    .case-row:nth-child(even) .case-image {
      order: -1;
    }

    .case-content {
      padding: 3rem 3.5rem 3rem 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .case-row:nth-child(even) .case-content {
      padding: 3rem 0 3rem 3.5rem;
    }

    .case-number {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.12em;
      margin-bottom: 1.5rem;
    }

    .case-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-bottom: 1.25rem;
    }

    .case-tag {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.7rem;
      border: 1px solid var(--rule);
      border-radius: 3px;
      color: var(--muted);
    }

    .case-name {
      font-family: var(--serif);
      font-size: clamp(1.9rem, 3vw, 2.75rem);
      line-height: 1.05;
      letter-spacing: -0.01em;
      margin-bottom: 1.1rem;
    }

    .case-description {
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--muted);
      max-width: 40ch;
      flex-grow: 1;
      margin-bottom: 1.75rem;
    }

    .case-outcome {
      font-family: var(--mono);
      font-size: 0.88rem;
      line-height: 1.6;
      border-left: 3px solid;
      padding-left: 1rem;
      margin-bottom: 2rem;
    }

    .case-cta {
      font-family: var(--serif);
      color: #7c8fd1;
      font-size: 1.3rem;
      letter-spacing: -0.01em;
      margin-bottom: 0.35rem;
      line-height: 1.2;
    }

    .case-cta:hover {
      opacity: 0.5;
    }

    .case-image {
      position: relative;
      overflow: hidden;
    }

    .case-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(15%);
      transition: filter 0.4s, transform 0.55s;
    }

    .case-row:hover .case-image img {
      filter: grayscale(0%);
      transform: scale(1.025);
    }

    .case-accent-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 5px;
    }

    /* ── OSS TABLE ── */
    .oss-section {
      padding: 0 0 6rem;
    }

    .oss-table {
      width: 100%;
      border-collapse: collapse;
    }

    .oss-table thead tr {
      border-bottom: 1px solid var(--rule);
    }

    .oss-table thead th {
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-align: left;
      padding: 0 0 0.9rem;
      font-weight: 400;
    }

    .oss-table thead th.th-right {
      text-align: right;
    }

    .oss-table tbody tr {
      border-bottom: 1px solid var(--rule);
      cursor: pointer;
      transition: background 0.15s;
    }

    .oss-table tbody tr:hover {
      background: var(--hover-bg);
    }

    .oss-table tbody td {
      padding: 1.6rem 0;
      vertical-align: middle;
    }

    .oss-num {
      width: 3rem;
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--muted);
      padding-right: 1.5rem;
    }

    .oss-title {
      color: var(--muted);
      font-size: 1.3rem;
      letter-spacing: -0.01em;
      margin-bottom: 0.35rem;
      line-height: 1.2;
    }

    .oss-desc {
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.6;
      max-width: 54ch;
    }

    .oss-tech-cell {
      padding-left: 2rem;
      vertical-align: middle;
    }

    .oss-tech-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      justify-content: flex-end;
    }

    .oss-tech {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--rule);
      padding: 0.2rem 0.55rem;
      border-radius: 3px;
    }

    .oss-year {
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--muted);
      white-space: nowrap;
      padding-left: 1.5rem;
      text-align: right;
    }

    .oss-arrow {
      padding-left: 1rem;
      text-align: right;
      font-size: 1rem;
      color: var(--muted);
      opacity: 0;
      transition: opacity 0.15s;
    }

    .oss-table tbody tr:hover .oss-arrow {
      opacity: 1;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .case-row {
        grid-template-columns: 1fr;
        min-height: unset;
      }

      .case-row:nth-child(even) .case-image {
        order: unset;
      }

      .case-image {
        height: 260px;
      }

      .case-content,
      .case-row:nth-child(even) .case-content {
        padding: 2rem 0;
      }

      .oss-tech-cell,
      .oss-arrow {
        display: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .case-row,
      .case-image img,
      .oss-table tbody tr {
        transition: none;
      }
    }
  </style>

  <div class="projects-root">
    <header class="masthead mt-8">
      <p class="masthead-eyebrow mt-8">Nick Stambaugh &mdash; Selected Work</p>
      <h1 class="masthead-headline">
        Things I've<br /><em>shipped.</em> <br />
      </h1>
    </header>
    <section class="cases-section">
      <p class="section-label">Case Studies &mdash; Client &amp; Product Work</p>
      <div>
        {featuredCases.map((c, i) => (
          <a class="case-row" href={c.link}>
            <div class="case-content">
              <div>
                <p class="case-number">
                  {String(i + 1).padStart(2, "0")} / {String(featuredCases.length).padStart(2, "0")}
                </p>
                <div class="case-tags">
                  {c.tags.map((t) => (
                    <span class="case-tag">{t}</span>
                  ))}
                </div>
                <h2 class="case-name">{c.name}</h2>
                <p class="case-description">{c.description}</p>
                <p class="case-outcome" style={`border-color: ${c.accent};`}>
                  {c.outcome}
                </p>
              </div>
              <span class="case-cta">
                {c.liveLink.startsWith("http") ? "Visit site →" : "Get in touch →"}
              </span>
            </div>
            <div class="case-image">
              <img src={c.image} alt={c.name} loading="lazy" />
              <div class="case-accent-bar" style={`background: ${c.accent};`} />
            </div>
          </a>
        ))}
      </div>
    </section>
    <section class="oss-section">
      <p class="section-label">Open Source &amp; Personal Projects</p>
      <table class="oss-table">
        <thead>
          <tr>
            <th></th>
            <th>Project</th>
            <th class="oss-tech-cell th-right">Stack</th>
            <th class="th-right">Year</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {openSourceProjects.map((p, i) => (
            <tr onclick={`window.open('${p.link}','_blank')`}>
              <td class="oss-num">{String(i + 1).padStart(2, "0")}</td>
              <td>
                <div class="oss-title">{p.title}</div>
                <div class="oss-desc">{p.description}</div>
              </td>
              <td class="oss-tech-cell">
                <div class="oss-tech-list">
                  {p.tech.map((t) => (
                    <span class="oss-tech">{t}</span>
                  ))}
                </div>
              </td>
              <td class="oss-year">{p.year}</td>
              <td class="oss-arrow">↗</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

  </div>
</BaseLayout>