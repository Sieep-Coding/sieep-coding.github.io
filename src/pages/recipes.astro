---
import BaseLayout from "../layouts/BaseLayout.astro";

const recipes = [
  {
    id: "reuben-sandwich",
    title: "Classic Reuben Sandwich",
    source: "sieep",
    year: "2026",
    time: "15 min",
    servings: "2 sandwiches",
    tags: ["sandwich", "deli", "quick"],
    description:
      "Corned beef, sauerkraut, swiss, and dressing, grilled between rye until it's crisp outside and melty inside.",
    ingredients: [
      "4 slices rye bread",
      "1/2 lb corned beef, sliced",
      "4 slices Swiss cheese",
      "1 cup sauerkraut, drained well",
      "1/4 cup Thousand Island dressing (or Russian dressing)",
      "2 tbsp butter, softened",
    ],
    steps: [
      "Warm the corned beef in a skillet or microwave so it's ready to melt the cheese.",
      "Butter one side of each slice of rye bread.",
      "On the unbuttered side of two slices, layer dressing, a slice of Swiss, corned beef, sauerkraut, another slice of Swiss, and more dressing. Top with the remaining bread, buttered side out.",
      "Grill in a skillet over medium heat, pressing gently, until golden brown, about 3-4 minutes per side.",
      "Flip carefully, brown the other side, and cook until the cheese is fully melted through.",
      "Slice in half and serve hot, with extra dressing on the side if you want it.",
    ],
    note: "Drain the sauerkraut well or the sandwich turns soggy fast — squeeze it out in a paper towel first.",
  },
  {
    id: "carbonara",
    title: "Bacon and Egg Coal Miner's Pasta: Rigatoni alla Carbonara",
    year: "2026",
    time: "17 min",
    servings: "4 generous servings",
    tags: ["pasta", "italian", "30-min"],
    description:
      "A classic carbonara built with pancetta instead of bacon, finished with egg yolks and Parmigiano off the heat so the sauce stays silky, not scrambled.",
    ingredients: [
      "Salt",
      "1 lb rigatoni",
      "1/3 lb pancetta, chopped",
      "Extra-virgin olive oil, a drizzle plus 2 tbsp",
      "4-5 cloves garlic, finely chopped",
      "1/4 tsp crushed red pepper flakes",
      "1/2 cup dry white wine or chicken stock",
      "2 large egg yolks",
      "3 tbsp grated Parmigiano Reggiano, plus more for serving",
      "A handful fresh parsley, finely chopped",
      "A few grinds black pepper",
    ],
    steps: [
      "Bring a large pot of salted water to a boil. Cook the rigatoni to al dente, about 8 minutes, and reserve 1/4 cup pasta water before draining.",
      "While the pasta cooks, brown the pancetta in a drizzle of oil over medium heat, 3-5 minutes. Add the olive oil, garlic, and red pepper flakes, and saute 2 minutes.",
      "Add the wine or stock and reduce by half, about 2 minutes.",
      "Whisk together the egg yolks and Parmigiano. While whisking, stream in a ladle of the hot pasta water to temper the eggs. Stir in the parsley and black pepper.",
      "Drain the pasta and add it to the pan with the pancetta. Toss to coat, then remove from heat and add the egg mixture, tossing for about a minute until the sauce thickens and clings to the pasta.",
      "Adjust salt and pepper, and serve immediately with extra Parmigiano for passing.",
    ],
    note: "Take the pan off the heat before adding the eggs — that's what keeps this a sauce and not scrambled eggs.",
  },
];
---

<BaseLayout title="Recipes — Nick Stambaugh">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24">
    <header class="space-y-4 mb-12">
      <h1
        class="text-3xl font-bold tracking-tight text-secondary dark:text-dk-accent"
      >
        Recipes
      </h1>
      <p class="text-lg text-text dark:text-dk-text/80 leading-relaxed">
        A small collection of things I cook. Some are mine, some are
        borrowed from better cooks.
      </p>
    </header>

    <div class="space-y-16">
      {recipes.map((recipe) => (
        <article
          id={recipe.id}
          class="border border-text/10 dark:border-dk-text/10 rounded-xl p-6 sm:p-8 bg-secondary/5 dark:bg-dk-secondary/5"
        >
          <header class="mb-6">
            <h2 class="text-xl font-semibold text-secondary dark:text-dk-accent">
              {recipe.title}
            </h2>

            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-text/60 dark:text-dk-text/60">
              <span>⏱ {recipe.time}</span>
              <span>🍽 {recipe.servings}</span>
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
              {recipe.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full border border-text/30 dark:border-dk-text/30 text-text/70 dark:text-dk-text/70">
                  {tag}
                </span>
              ))}
            </div>

            <p class="mt-4 text-text dark:text-dk-text/80 leading-relaxed">
              {recipe.description}
            </p>
          </header>

          <div class="grid sm:grid-cols-2 gap-8">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-text/60 dark:text-dk-text/60 mb-3">
                Ingredients
              </h3>
              <ul class="list-disc list-inside space-y-1.5 text-sm text-text/80 dark:text-dk-text/80">
                {recipe.ingredients.map((ing) => <li>{ing}</li>)}
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-text/60 dark:text-dk-text/60 mb-3">
                Directions
              </h3>
              <ol class="list-decimal list-inside space-y-2 text-sm text-text/80 dark:text-dk-text/80">
                {recipe.steps.map((step) => <li>{step}</li>)}
              </ol>
            </div>
          </div>

          {recipe.note && (
            <p class="mt-6 text-xs text-text/50 dark:text-dk-text/50 border-t border-text/10 dark:border-dk-text/10 pt-4">
              <strong>Note:</strong> {recipe.note}
            </p>
          )}
        </article>
      ))}
    </div>

    <footer class="mt-16 pt-8 border-t border-text/10 dark:border-dk-text/10">
      <a
        href="/"
        class="text-sm text-text/60 hover:text-secondary dark:hover:text-dk-accent transition-colors"
      >
        ← Back to home
      </a>
    </footer>
  </main>
</BaseLayout>