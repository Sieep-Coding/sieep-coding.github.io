---
import BaseLayout from "../layouts/BaseLayout.astro";

const recipes = [
  {
    id: "reuben-sandwich",
    title: "Classic Reuben Sandwich",
    source: "sieep",
    year: "2026",
    time: "15 min",
    servings: "2 sandwiches",
    tags: ["sandwich", "deli", "quick", "jewish", "comfort-food"],
    description:
      "Corned beef, sauerkraut, swiss, and dressing, grilled between rye until it's crisp outside and melty inside.",
    ingredients: [
      "4 slices rye bread",
      "1/2 lb corned beef, sliced",
      "4 slices Swiss cheese",
      "1 cup sauerkraut, drained well",
      "1/4 cup Thousand Island dressing (or Russian dressing)",
      "2 tbsp butter, softened",
    ],
    steps: [
      "Warm the corned beef in a skillet or microwave so it's ready to melt the cheese.",
      "Butter one side of each slice of rye bread.",
      "On the unbuttered side of two slices, layer dressing, a slice of Swiss, corned beef, sauerkraut, another slice of Swiss, and more dressing. Top with the remaining bread, buttered side out.",
      "Grill in a skillet over medium heat, pressing gently, until golden brown, about 3-4 minutes per side.",
      "Flip carefully, brown the other side, and cook until the cheese is fully melted through.",
      "Slice in half and serve hot, with extra dressing on the side if you want it.",
    ],
    note: "Drain the sauerkraut well or the sandwich turns soggy fast. Squeeze it out in a paper towel first.",
  },
  {
    id: "vodka-meatball-bake",
    title: "Vodka Meatball Rigatoni Bake",
    year: "2026",
    time: "45 min",
    servings: "6",
    tags: ["italian", "pasta", "baked"],
    description:
      "Rigatoni tossed in creamy vodka sauce with homemade meatballs, topped with mozzarella and baked until bubbly with crispy golden edges.",
    ingredients: [
      "1 lb rigatoni",
      "1 lb Italian sausage or ground beef meatballs",
      "24 oz vodka sauce",
      "2 cups shredded mozzarella",
      "1/2 cup grated Parmigiano Reggiano",
      "Fresh basil",
    ],
    steps: [
      "Cook the rigatoni until just shy of al dente.",
      "Brown or bake the meatballs until cooked through.",
      "Mix the pasta, vodka sauce, and meatballs together.",
      "Transfer to a baking dish and top with mozzarella and Parmigiano.",
      "Bake at 400°F for 20-25 minutes until golden and bubbling.",
      "Finish with fresh basil before serving.",
    ],
    note: "Undercook the pasta slightly so it finishes perfectly in the oven.",
  },
  {
    id: "pad-kra-pao",
    title: "Pad Kra Pao (Thai Basil Chicken)",
    year: "2026",
    time: "20 min",
    servings: "4",
    tags: ["thai", "30-min", "quick"],
    description:
      "Ground chicken stir-fried with garlic, chilies, and Thai basil in a savory, slightly sweet sauce. Serve it over jasmine rice with a crispy fried egg if you really want the full experience.",
    ingredients: [
      "1 lb ground chicken",
      "4 cloves garlic, minced",
      "2 Thai chilies, sliced",
      "2 tbsp vegetable oil",
      "2 tbsp oyster sauce",
      "1 tbsp soy sauce",
      "1 tsp fish sauce",
      "1 tsp sugar",
      "1 cup Thai basil leaves",
      "Cooked jasmine rice",
      "4 eggs (optional)",
    ],
    steps: [
      "Heat the oil in a large skillet or wok over high heat.",
      "Cook the garlic and chilies for about 30 seconds until fragrant.",
      "Add the ground chicken and cook until browned, breaking it apart as it cooks.",
      "Stir in the oyster sauce, soy sauce, fish sauce, and sugar.",
      "Turn off the heat and toss in the Thai basil until just wilted.",
      "Serve over jasmine rice with a fried egg on top if you're making one.",
    ],
    note: "Add the basil at the very end so it stays bright and fragrant.",
  },
  {
    id: "thai-fried-rice",
    title: "Thai Fried Rice (Khao Pad)",
    year: "2026",
    time: "20 min",
    servings: "4",
    tags: ["thai", "rice", "quick"],
    description:
      "Simple Thai-style fried rice with chicken, egg, garlic, and vegetables tossed in a light soy and fish sauce. Great way to use up leftover rice.",
    ingredients: [
      "4 cups cooked day-old jasmine rice",
      "1 lb chicken breast, diced",
      "2 eggs",
      "3 cloves garlic, minced",
      "1 small onion, diced",
      "1 cup frozen peas and carrots",
      "2 tbsp soy sauce",
      "1 tbsp fish sauce",
      "2 tbsp vegetable oil",
      "Green onions, sliced",
      "Lime wedges",
    ],
    steps: [
      "Heat the oil in a large skillet or wok and cook the chicken until browned.",
      "Add the onion and garlic and cook for 2 minutes.",
      "Push everything to one side and scramble the eggs.",
      "Add the rice and peas and carrots, breaking up any clumps.",
      "Stir in the soy sauce and fish sauce, then toss everything together until hot.",
      "Top with green onions and serve with fresh lime wedges.",
    ],
    note: "Day-old cold rice fries much better than freshly cooked rice and won't turn mushy.",
  },
  {
    id: "chicken-parm-garlic-bread",
    title: "Chicken Parmesan Garlic Bread",
    year: "2026",
    time: "35 min",
    servings: "4",
    tags: ["italian", "sandwich", "comfort-food"],
    description:
      "Crunchy garlic bread stuffed with crispy chicken parmesan, melty mozzarella, marinara, and fresh basil. Messy in the best way possible.",
    ingredients: [
      "1 loaf Italian bread",
      "2 breaded chicken cutlets",
      "1 cup marinara sauce",
      "8 oz fresh mozzarella",
      "4 tbsp garlic butter",
      "Fresh basil",
      "Grated Parmigiano Reggiano",
    ],
    steps: [
      "Slice the loaf open and spread both sides with garlic butter.",
      "Toast until lightly golden.",
      "Layer the chicken cutlets, marinara, mozzarella, basil, and Parmigiano.",
      "Bake at 400°F until the cheese is melted and bubbly.",
      "Slice into large sandwiches and serve hot.",
    ],
    note: "Toast the bread first so it doesn't get soggy from the sauce.",
  },
  {
    id: "sausage-peppers-polenta",
    title: "Creamy Polenta with Italian Sausage and Peppers",
    year: "2026",
    time: "40 min",
    servings: "4",
    tags: ["italian", "comfort-food", "30-min"],
    description:
      "Creamy Parmesan polenta piled high with browned Italian sausage, sweet peppers, onions, and a rich tomato pan sauce.",
    ingredients: [
      "1 cup polenta",
      "4 cups chicken stock",
      "1/2 cup grated Parmigiano Reggiano",
      "1 lb Italian sausage",
      "2 bell peppers, sliced",
      "1 onion, sliced",
      "2 cloves garlic, minced",
      "1 cup crushed tomatoes",
      "Olive oil",
      "Salt and black pepper",
    ],
    steps: [
      "Cook the polenta in chicken stock until creamy, then stir in the Parmigiano.",
      "Brown the sausage and slice into bite-sized pieces.",
      "Cook the peppers, onion, and garlic until softened.",
      "Add the tomatoes and simmer for 10 minutes.",
      "Spoon the creamy polenta into bowls and top with the sausage mixture.",
      "Finish with extra Parmigiano and black pepper.",
    ],
    note: "Keep whisking the polenta while it cooks so it stays smooth and creamy.",
  },
  {
    id: "carbonara",
    title: "Bacon and Egg Coal Miner's Pasta: Rigatoni alla Carbonara",
    year: "2026",
    time: "17 min",
    servings: "4 generous servings",
    tags: ["pasta", "italian", "30-min"],
    description:
      "A classic carbonara built with pancetta instead of bacon, finished with egg yolks and Parmigiano off the heat so the sauce stays silky, not scrambled.",
    ingredients: [
      "Salt",
      "1 lb rigatoni",
      "1/3 lb pancetta, chopped",
      "Extra-virgin olive oil, a drizzle plus 2 tbsp",
      "4-5 cloves garlic, finely chopped",
      "1/4 tsp crushed red pepper flakes",
      "1/2 cup dry white wine or chicken stock",
      "2 large egg yolks",
      "3 tbsp grated Parmigiano Reggiano, plus more for serving",
      "A handful fresh parsley, finely chopped",
      "A few grinds black pepper",
    ],
    steps: [
      "Bring a large pot of salted water to a boil. Cook the rigatoni to al dente, about 8 minutes, and reserve 1/4 cup pasta water before draining.",
      "While the pasta cooks, brown the pancetta in a drizzle of oil over medium heat, 3-5 minutes. Add the olive oil, garlic, and red pepper flakes, and saute 2 minutes.",
      "Add the wine or stock and reduce by half, about 2 minutes.",
      "Whisk together the egg yolks and Parmigiano. While whisking, stream in a ladle of the hot pasta water to temper the eggs. Stir in the parsley and black pepper.",
      "Drain the pasta and add it to the pan with the pancetta. Toss to coat, then remove from heat and add the egg mixture, tossing for about a minute until the sauce thickens and clings to the pasta.",
      "Adjust salt and pepper, and serve immediately with extra Parmigiano for passing.",
    ],
    note: "Take the pan off the heat before adding the eggs. That's what keeps this a sauce and not scrambled eggs.",
  },
  {
    id: "brisket-knish-melt",
    title: "Brisket Knish Melt",
    year: "2026",
    time: "30 min",
    servings: "4",
    tags: ["jewish", "comfort-food", "sandwich"],
    description:
      "A crispy potato knish split open and stuffed with tender brisket, caramelized onions, Swiss cheese, and spicy deli mustard, then grilled until everything melts together.",
    ingredients: [
      "4 potato knishes",
      "1 lb cooked brisket, sliced or shredded",
      "1 large onion, sliced",
      "4 slices Swiss cheese",
      "2 tbsp spicy brown mustard",
      "2 tbsp butter",
    ],
    steps: [
      "Caramelize the onions in butter over medium-low heat until deep golden.",
      "Warm the brisket in a skillet with a splash of beef broth if needed.",
      "Slice each knish almost all the way through like a sandwich roll.",
      "Spread mustard inside, then layer brisket, onions, and Swiss cheese.",
      "Grill each stuffed knish in a buttered skillet until crisp outside and the cheese is melted.",
      "Serve hot with pickles on the side.",
    ],
    note: "Don't overstuff the knishes or they'll split apart while grilling.",
  },
  {
    id: "matzo-ball-chicken-pot-pie",
    title: "Matzo Ball Chicken Pot Pie",
    year: "2026",
    time: "55 min",
    servings: "6",
    tags: ["jewish", "comfort-food", "baked"],
    description:
      "Everything you'd want from chicken soup, baked into a creamy pot pie and topped with sliced matzo balls instead of pie crust.",
    ingredients: [
      "2 cups cooked chicken, shredded",
      "2 cups chicken broth",
      "1 cup heavy cream",
      "1 cup carrots, diced",
      "1 cup celery, diced",
      "1 small onion, diced",
      "2 tbsp butter",
      "2 tbsp flour",
      "4 cooked matzo balls, sliced",
      "Salt and pepper",
      "Fresh parsley",
    ],
    steps: [
      "Cook the carrots, celery, and onion in butter until softened.",
      "Stir in the flour and cook for a minute, then slowly whisk in the broth and cream.",
      "Add the chicken and season with salt, pepper, and parsley.",
      "Pour into a baking dish and arrange the sliced matzo balls across the top.",
      "Bake at 400°F for about 25 minutes until bubbling and lightly browned.",
      "Let cool for 5 minutes before serving.",
    ],
    note: "Use day-old matzo balls so they hold their shape while baking.",
  },
  {
    id: "uzbek-lamb-kebab",
    title: "Uzbek Lamb Kebab",
    year: "2026",
    time: "35 min",
    servings: "4",
    tags: ["uzbek", "grill", "lamb"],
    description:
      "Tender chunks of lamb marinated with onion and simple spices, then grilled until smoky and juicy. Serve with flatbread, sliced onions, and fresh tomatoes.",
    ingredients: [
      "2 lbs lamb shoulder, cut into cubes",
      "1 large onion, grated",
      "2 tbsp vegetable oil",
      "1 tsp ground cumin",
      "1 tsp paprika",
      "1 tsp black pepper",
      "1 tsp salt",
      "Metal or soaked wooden skewers",
    ],
    steps: [
      "Mix the lamb with the grated onion, oil, cumin, paprika, pepper, and salt.",
      "Marinate for at least 1 hour or overnight if you have time.",
      "Thread the lamb onto skewers.",
      "Grill over medium-high heat for 10-12 minutes, turning every few minutes until browned and cooked through.",
      "Serve with flatbread, raw sliced onions, and tomatoes.",
    ],
    note: "Grated onion helps tenderize the lamb while adding a ton of flavor.",
  },
  {
    id: "uzbek-plov",
    title: "Simple Uzbek Plov",
    year: "2026",
    time: "1 hr",
    servings: "6",
    tags: ["uzbek", "rice", "comfort-food"],
    description:
      "A classic one-pot rice dish with lamb, carrots, onions, and cumin. It's hearty, simple, and one of the most well-known dishes in Uzbekistan.",
    ingredients: [
      "2 lbs lamb, cubed",
      "2 cups long-grain rice",
      "2 large carrots, cut into matchsticks",
      "2 onions, sliced",
      "4 cups beef broth",
      "1 whole head of garlic",
      "2 tsp ground cumin",
      "2 tbsp vegetable oil",
      "Salt and black pepper",
    ],
    steps: [
      "Rinse the rice until the water runs mostly clear.",
      "Brown the lamb in the oil, then add the onions and cook until softened.",
      "Add the carrots and cumin and cook for about 5 minutes.",
      "Pour in the broth and nestle the whole head of garlic into the pot.",
      "Spread the rice evenly over the top without stirring.",
      "Cover and simmer on low for about 25 minutes until the rice is tender and the liquid is absorbed.",
      "Remove the garlic, fluff the rice, and gently mix everything together before serving.",
    ],
    note: "Don't stir the rice while it cooks or it'll lose the classic plov texture.",
  },
  {
    id: "vanilla-latte",
    title: "Simple Vanilla Latte",
    year: "2026",
    time: "5 min",
    servings: "1",
    tags: ["drink", "coffee", "quick"],
    description:
      "A smooth espresso drink with steamed milk and just enough vanilla to sweeten it without overpowering the coffee.",
    ingredients: ["2 shots espresso", "1 cup milk", "1 tbsp vanilla syrup"],
    steps: [
      "Brew the espresso into a mug.",
      "Stir in the vanilla syrup.",
      "Steam or heat the milk until hot and frothy.",
      "Pour the milk over the espresso and spoon the foam on top.",
      "Serve immediately.",
    ],
    note: "No espresso machine? Strong brewed coffee works surprisingly well.",
  },
  {
    id: "honey-green-tea",
    title: "Honey Green Tea",
    year: "2026",
    time: "5 min",
    servings: "1",
    tags: ["drink", "tea", "easy"],
    description:
      "A light, soothing green tea sweetened with honey and finished with a squeeze of fresh lemon.",
    ingredients: [
      "1 green tea bag",
      "8 oz hot water",
      "1 tbsp honey",
      "1 lemon wedge",
    ],
    steps: [
      "Steep the green tea in hot water for 2-3 minutes.",
      "Remove the tea bag and stir in the honey.",
      "Squeeze in the lemon juice.",
      "Serve hot.",
    ],
    note: "Avoid boiling water if possible, slightly cooler water keeps green tea from turning bitter.",
  },
  {
    id: "pastrami-latke-stack",
    title: "Pastrami Latke Stack",
    year: "2026",
    time: "25 min",
    servings: "4",
    tags: ["jewish", "deli", "quick"],
    description:
      "Golden latkes layered with hot pastrami, melted Swiss, tangy slaw, and a swipe of Russian dressing for a deli-style dinner that's way better than it has any right to be.",
    ingredients: [
      "8 potato latkes",
      "3/4 lb pastrami, warmed",
      "4 slices Swiss cheese",
      "1 cup coleslaw",
      "1/4 cup Russian dressing",
      "Butter",
    ],
    steps: [
      "Crisp the latkes in a skillet with a little butter.",
      "Warm the pastrami until hot.",
      "Top four latkes with pastrami and Swiss cheese, then cover briefly so the cheese melts.",
      "Add a spoonful of coleslaw and a drizzle of Russian dressing.",
      "Finish with another crispy latke and serve immediately.",
    ],
    note: "Keep the slaw cold so you get that hot-and-cold deli contrast.",
  },
];

// Build tag set
const tags = new Set();
for (const r of recipes) {
  (r.tags || []).forEach((t) => tags.add(t));
}

const slug = (t) =>
  t
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, "")
    .replace(/[\s_-]+/g, "-");
---

<BaseLayout title="Recipes — Nick Stambaugh">
  <main class="max-w-2xl mx-auto px-4 py-16 sm:py-24">
    <header class="space-y-4 mb-12">
      <h1
        class="text-3xl font-bold tracking-tight text-secondary dark:text-dk-accent"
      >
        Recipes
      </h1>
      <p class="text-lg text-text dark:text-dk-text/80 leading-relaxed">
        A small collection of things I cook. Breaking American stereotypes one
        recipe at a time.
      </p>
      <p class="text-xs text-text/50 dark:text-dk-text/50">
        {recipes.length} recipes · tap a card to open it
      </p>
    </header>

    <!-- Search & Filter Toggle -->
    <div
      class="relative flex items-center mb-4 border-b-2 border-text/40 dark:border-dk-text/40 focus-within:border-secondary dark:focus-within:border-dk-accent transition-colors pb-1"
    >
      <input
        id="recipe-search"
        type="text"
        placeholder="Search recipes..."
        class="w-full py-3 bg-transparent text-text dark:text-dk-accent placeholder-text/60 dark:placeholder-dk-text/60 focus:outline-none text-xl font-medium tracking-wide"
      />

      <button
        id="filters-toggle"
        class="ml-4 px-4 py-2 text-sm uppercase font-bold tracking-widest text-text dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors focus:outline-none flex items-center gap-1"
      >
        <span>Tags</span>
        <span
          id="filters-arrow"
          class="inline-block transition-transform duration-200 text-xs">↓</span
        >
      </button>
    </div>

    <!-- Collapsible Tag Panel -->
    <div
      id="filters-panel"
      class="overflow-hidden transition-[max-height] duration-200 ease-out max-h-0"
    >
      <div
        id="tag-filter"
        class="flex flex-wrap gap-x-6 gap-y-3 pt-3 pb-8 border-b-2 border-text/10 dark:border-dk-text/10"
      >
        <button
          data-filter="*"
          class="tag-btn text-sm lowercase font-bold tracking-wide text-secondary dark:text-dk-accent decoration-secondary dark:decoration-dk-accent hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 underline-offset-8"
        >
          all
        </button>

        {
          Array.from(tags).map((tag) => (
            <button
              data-filter={`.${slug(tag)}`}
              class="tag-btn text-sm lowercase font-bold tracking-wide text-text/70 dark:text-dk-text hover:text-secondary dark:hover:text-dk-accent transition-colors underline decoration-2 decoration-transparent underline-offset-8"
            >
              {tag}
            </button>
          ))
        }
      </div>
    </div>

    <p
      id="no-results"
      class="hidden text-sm text-text/50 dark:text-dk-text/50 mb-8"
    >
      No recipes match your search.
    </p>

    <!-- Accordion list: collapsed by default, click to expand -->
    <div class="space-y-3" id="recipes-list">
      {
        recipes.map((recipe) => {
          const tagClasses = (recipe.tags || []).map((t) => slug(t)).join(" ");
          const tagsStr = (recipe.tags || []).join(",");
          return (
            <article
              id={recipe.id}
              class={`recipe-item ${tagClasses} border border-text/10 dark:border-dk-text/10 rounded-xl bg-secondary/5 dark:bg-dk-secondary/5 overflow-hidden`}
              data-title={recipe.title.toLowerCase()}
              data-tags={tagsStr.toLowerCase()}
              data-description={recipe.description.toLowerCase()}
            >
              <button
                class="recipe-toggle w-full text-left flex items-start justify-between gap-4 p-5 sm:p-6 cursor-pointer"
                aria-expanded="false"
              >
                <div class="min-w-0">
                  <h2 class="text-lg font-semibold text-secondary dark:text-dk-accent">
                    {recipe.title}
                  </h2>

                  <div class="mt-1.5 flex flex-wrap gap-x-3 gap-y-1 text-xs text-text/60 dark:text-dk-text/60">
                    <span>⏱ {recipe.time}</span>
                    <span>🍽 {recipe.servings}</span>
                  </div>

                  <p class="mt-2 text-sm text-text/80 dark:text-dk-text/80 leading-relaxed">
                    {recipe.description}
                  </p>

                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {recipe.tags.map((tag) => (
                      <span class="text-[11px] px-2 py-0.5 rounded-full border border-text/30 dark:border-dk-text/30 text-text/70 dark:text-dk-text/70">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <span
                  class="recipe-arrow shrink-0 mt-1 text-text/40 dark:text-dk-text/40 transition-transform duration-200"
                  aria-hidden="true"
                >
                  ↓
                </span>
              </button>

              <div class="recipe-panel overflow-hidden transition-[max-height] duration-300 ease-out max-h-0">
                <div class="px-5 sm:px-6 pb-6 pt-2 border-t border-text/10 dark:border-dk-text/10">
                  <div class="grid sm:grid-cols-2 gap-8 mt-4">
                    <div>
                      <h3 class="text-sm font-semibold uppercase tracking-wide text-text/60 dark:text-dk-text/60 mb-3">
                        Ingredients
                      </h3>
                      <ul class="list-disc list-inside space-y-1.5 text-sm text-text/80 dark:text-dk-text/80">
                        {recipe.ingredients.map((ing) => (
                          <li>{ing}</li>
                        ))}
                      </ul>
                    </div>

                    <div>
                      <h3 class="text-sm font-semibold uppercase tracking-wide text-text/60 dark:text-dk-text/60 mb-3">
                        Directions
                      </h3>
                      <ol class="list-decimal list-inside space-y-2 text-sm text-text/80 dark:text-dk-text/80">
                        {recipe.steps.map((step) => (
                          <li>{step}</li>
                        ))}
                      </ol>
                    </div>
                  </div>

                  {recipe.note && (
                    <p class="mt-6 text-xs text-text/50 dark:text-dk-text/50 border-t border-text/10 dark:border-dk-text/10 pt-4">
                      <strong>Note:</strong> {recipe.note}
                    </p>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <footer class="mt-16 pt-8 border-t border-text/10 dark:border-dk-text/10">
      <a
        href="/"
        class="text-sm text-text/60 hover:text-secondary dark:hover:text-dk-accent transition-colors"
      >
        ← Back to home
      </a>
    </footer>
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const searchEl = document.getElementById("recipe-search");
      const tagButtons = Array.from(document.querySelectorAll(".tag-btn"));
      const items = Array.from(document.querySelectorAll(".recipe-item"));
      const noResults = document.getElementById("no-results");

      let activeFilter = "*";

      const applyFilters = () => {
        const query = searchEl.value.toLowerCase();
        let visibleCount = 0;

        items.forEach((item) => {
          const title = item.dataset.title || "";
          const tags = item.dataset.tags || "";
          const description = item.dataset.description || "";
          const textMatch =
            title.includes(query) ||
            tags.includes(query) ||
            description.includes(query);
          const filterMatch =
            activeFilter === "*" ||
            item.classList.contains(activeFilter.slice(1));

          const show = textMatch && filterMatch;
          item.style.display = show ? "block" : "none";
          if (show) visibleCount++;
        });

        noResults.classList.toggle("hidden", visibleCount !== 0);
      };

      tagButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          tagButtons.forEach((b) => {
            b.classList.remove(
              "text-secondary",
              "dark:text-dk-accent",
              "decoration-secondary",
              "dark:decoration-dk-accent",
            );
            b.classList.add("text-text/70", "dark:text-dk-text");
          });

          btn.classList.remove("text-text/70", "dark:text-dk-text");
          btn.classList.add(
            "text-secondary",
            "dark:text-dk-accent",
            "decoration-secondary",
            "dark:decoration-dk-accent",
          );

          activeFilter = btn.dataset.filter;
          applyFilters();
        });
      });

      searchEl.addEventListener("input", applyFilters);

      /* Tag filter collapsible panel */
      const panel = document.getElementById("filters-panel");
      const toggle = document.getElementById("filters-toggle");
      const arrow = document.getElementById("filters-arrow");

      let open = false;
      panel.style.maxHeight = "0px";

      toggle.addEventListener("click", () => {
        open = !open;
        if (open) {
          panel.style.maxHeight = panel.scrollHeight + "px";
          arrow.style.transform = "rotate(180deg)";
        } else {
          panel.style.maxHeight = "0px";
          arrow.style.transform = "rotate(0deg)";
        }
      });

      /* Recipe accordion: click a card to expand/collapse its content */
      items.forEach((item) => {
        const toggleBtn = item.querySelector(".recipe-toggle");
        const recipePanel = item.querySelector(".recipe-panel");
        const recipeArrow = item.querySelector(".recipe-arrow");

        toggleBtn.addEventListener("click", () => {
          const isOpen = toggleBtn.getAttribute("aria-expanded") === "true";
          toggleBtn.setAttribute("aria-expanded", String(!isOpen));

          if (isOpen) {
            recipePanel.style.maxHeight = "0px";
            recipeArrow.style.transform = "rotate(0deg)";
          } else {
            recipePanel.style.maxHeight = recipePanel.scrollHeight + "px";
            recipeArrow.style.transform = "rotate(180deg)";
          }
        });
      });

      applyFilters();
    });
  </script>
</BaseLayout>
