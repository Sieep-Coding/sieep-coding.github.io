---
import ShopLayout from "../../layouts/ShopLayout.astro";
import { allProducts } from "../../data/shop";

export async function getStaticPaths() {
  return allProducts.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

const placeholder =
  "https://placehold.co/1200x1200/png?text=No+Image";

const formatPrice = (cents: number) =>
  cents === 0 ? "Free" : `$${(cents / 100).toFixed(2)}`;

const isPrint = product.type === "print";
const isMusic = !isPrint;

const typeLabel = (type: string) => {
  if (type === "album") return "Album";
  if (type === "ep") return "EP";
  if (type === "single") return "Single";
  return "Framed Print";
};
---

<ShopLayout title={`${product.title} — Shop`}>

  <div class="max-w-4xl">
    <a href="/shop" class="inline-flex items-center gap-2 text-sm text-[#202020]/50 dark:text-[#96a6e2]/50 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors mb-8">
      <i class="fa fa-arrow-left text-xs"></i> Back to shop
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Image -->
      <div>
        <div class={`rounded-lg overflow-hidden bg-[#202020]/5 dark:bg-[#7c8fd1]/5 ${isPrint ? "aspect-[3/4]" : "aspect-square"}`}>
          <img
            src={placeholder}
            alt={product.title}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        {isMusic && product.streamUrl && (
          <a
            href={product.streamUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 flex items-center gap-2 text-sm text-[#202020]/50 dark:text-[#96a6e2]/50 hover:text-[#202020] dark:hover:text-[#96a6e2] transition-colors"
          >
            <i class="fab fa-spotify"></i> Stream on Spotify
          </a>
        )}
      </div>

      <!-- Details -->
      <div class="flex flex-col">

        <div class="mb-6">
          <p class="text-xs tracking-[0.2em] uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-2">
            {typeLabel(product.type)}
            {isMusic && product.releaseYear && ` · ${product.releaseYear}`}
          </p>
          <h1 class="text-2xl lg:text-3xl font-bold text-[#202020] dark:text-[#7c8fd1]">{product.title}</h1>
          <p class="mt-3 text-[#202020]/70 dark:text-[#96a6e2]/70 leading-relaxed">{product.description}</p>
        </div>

        {/* Print sizes */}
        {isPrint && product.sizes && (
          <div class="mb-6">
            <p class="text-xs tracking-widest uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-3">Size</p>
            <div class="flex flex-col gap-2" id="size-options">
              {product.sizes.map((size, i) => (
                <label class="flex items-center justify-between p-3 border border-[#202020]/15 dark:border-[#7c8fd1]/20 rounded cursor-pointer hover:border-[#202020]/40 dark:hover:border-[#7c8fd1]/50 transition-colors has-[:checked]:border-[#202020] dark:has-[:checked]:border-[#7c8fd1]">
                  <div class="flex items-center gap-3">
                    <input
                      type="radio"
                      name="size"
                      value={size.stripePriceId}
                      checked={i === 0}
                      class="accent-[#202020] dark:accent-[#7c8fd1]"
                    />
                    <span class="text-sm font-mono text-[#202020] dark:text-[#96a6e2]">{size.label}</span>
                  </div>
                  <span class="text-sm font-mono text-[#202020] dark:text-[#96a6e2]">{formatPrice(size.price)}</span>
                </label>
              ))}
            </div>
          </div>
        )}

        {/* Print metadata */}
        {isPrint && (
          <div class="mb-6 grid grid-cols-2 gap-3 text-sm">
            {product.medium && (
              <div>
                <p class="text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 mb-0.5">Medium</p>
                <p class="text-[#202020] dark:text-[#96a6e2]">{product.medium}</p>
              </div>
            )}
            {product.dimensions && (
              <div>
                <p class="text-xs text-[#202020]/40 dark:text-[#96a6e2]/40 mb-0.5">Dimensions</p>
                <p class="text-[#202020] dark:text-[#96a6e2]">{product.dimensions}</p>
              </div>
            )}
          </div>
        )}

        {/* Tracklist */}
        {isMusic && product.tracklist && (
          <div class="mb-6">
            <p class="text-xs tracking-widest uppercase text-[#202020]/40 dark:text-[#96a6e2]/40 mb-3">Tracklist</p>
            <ol class="flex flex-col gap-1">
              {product.tracklist.map((track, i) => (
                <li class="flex items-center gap-3 text-sm py-1.5 border-b border-[#202020]/5 dark:border-[#7c8fd1]/10">
                  <span class="font-mono text-xs text-[#202020]/30 dark:text-[#96a6e2]/30 w-5 text-right flex-shrink-0">
                    {i + 1}
                  </span>
                  <span class="text-[#202020] dark:text-[#96a6e2]">{track}</span>
                </li>
              ))}
            </ol>
          </div>
        )}

        {/* Tags */}
        {product.tags && (
          <div class="flex flex-wrap gap-1 mb-8">
            {product.tags.map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded border border-[#202020]/15 dark:border-[#7c8fd1]/20 text-[#202020]/50 dark:text-[#96a6e2]/50">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Price + Buy -->
        <div class="mt-auto">
          <div class="flex items-baseline gap-3 mb-4">
            <span class="text-2xl font-mono font-bold text-[#202020] dark:text-[#7c8fd1]" id="display-price">
              {formatPrice(product.price)}
            </span>

            {isPrint && (
              <span class="text-sm text-[#202020]/40 dark:text-[#96a6e2]/40">+ shipping</span>
            )}

            {isMusic && product.price === 0 && (
              <span class="text-sm text-[#202020]/40 dark:text-[#96a6e2]/40">name your price</span>
            )}
          </div>

          <button
            id="buy-btn"
            data-price-id={product.sizes ? product.sizes[0].stripePriceId : product.stripePriceId}
            class="w-full py-3 px-6 bg-[#202020] dark:bg-[#7c8fd1] text-[#e8d8c8] dark:text-[#2a2b39] font-semibold rounded hover:opacity-90 transition-opacity font-mono tracking-wide"
          >
            {product.price === 0 ? "Download Free" : "Buy Now"}
          </button>

          <p class="text-xs text-center text-[#202020]/30 dark:text-[#96a6e2]/30 mt-3">
            Secure checkout via Stripe
          </p>
        </div>

      </div>
    </div>
  </div>

</ShopLayout>

<script>
  const radios = document.querySelectorAll('input[name="size"]');
  const buyBtn = document.getElementById("buy-btn");

  radios.forEach((radio) => {
    radio.addEventListener("change", (e) => {
      const target = e.target as HTMLInputElement;
      if (buyBtn && target) buyBtn.setAttribute("data-price-id", target.value);
    });
  });

  buyBtn?.addEventListener("click", async () => {
    const priceId = buyBtn.getAttribute("data-price-id");
    if (!priceId || priceId === "price_REPLACE_ME") {
      alert("Checkout not yet configured — replace Stripe price IDs in data/shop.ts");
      return;
    }

    buyBtn.textContent = "Redirecting...";
    buyBtn.classList.add("opacity-60", "pointer-events-none");

    try {
      const res = await fetch("/api/checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ priceId }),
      });

      const { url } = await res.json();
      if (url) window.location.href = url;
    } catch (err) {
      buyBtn.textContent = "Something went wrong";
      buyBtn.classList.remove("opacity-60", "pointer-events-none");
    }
  });
</script>