<div
  id="announcement-banner"
  class="w-full bg-accent dark:bg-dk-accent text-primary dark:text-dk-primary text-sm py-2 px-4 flex items-center justify-center gap-2"
>
  <span>
    This site has moved to
    <strong>nickstambaugh.com</strong> —
    <a
      href="/posts/moving-to-dot-com"
      class="underline underline-offset-2 hover:opacity-75 transition-opacity"
    >
      here's why
    </a>.
  </span>
  <button
    id="dismiss-banner"
    aria-label="Dismiss announcement"
    class="ml-2 leading-none opacity-60 hover:opacity-100 transition-opacity text-base"
  >
    ×
  </button>
</div>

<script>
  const BANNER_KEY = "banner-dismissed-move-to-com";
  const banner = document.getElementById("announcement-banner");
  const dismiss = document.getElementById("dismiss-banner");

  // Hide immediately if already dismissed
  if (localStorage.getItem(BANNER_KEY)) {
    banner?.remove();
  }

  dismiss?.addEventListener("click", () => {
    localStorage.setItem(BANNER_KEY, "1");
    banner?.remove();
  });
</script>
