---
const K = 7;

const { posts } = Astro.props;

const recentPosts = posts
  .sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, K);
---

<div class="space-y-8">
  <header class="pb-4">
    <h2 class="text-xl font-bold tracking-tight">Recent Writing</h2>
  </header>
  
  <!-- Removed divide-y and divide-zinc-100 classes here -->
  <div class="space-y-8">
    {recentPosts.map((post: any) => (
      <!-- Removed pt-6 and first:pt-0 here -->
      <article class="group">
        <div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400 mb-2">
          <time datetime={post.frontmatter.date}>{post.frontmatter.date}</time>
          {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
            <span>•</span>
            <span class="font-medium uppercase tracking-wider">{post.frontmatter.tags.join(", ")}</span>
          )}
        </div>
        
        <h3 class="text-lg font-semibold text-zinc-900 dark:text-white transition-colors hover:underline">
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>
        
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {post.frontmatter.description}
        </p>
        
        <a href={post.url} class="inline-flex items-center gap-1 text-sm font-medium text-text dark:text-primary mt-3 hover:underline">
          Read article &rarr;
        </a>
      </article>
    ))}
  </div>

  <div class="pt-4 mb-5">
    <a class="text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-primary dark:hover:text-white transition-colors underline underline-offset-4" href="/posts">
      View all posts &rarr;
    </a>
            <div class="mt-6">
          <a
            href="/about"
            class="text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-primary dark:hover:text-white transition-colors underline underline-offset-4"
          >
            Read about Nick →
          </a>
        </div>
  </div>
</div>
