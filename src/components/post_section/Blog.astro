---
const K = 7;

const { posts } = Astro.props;

const sortedPosts = posts
  .slice()
  .sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const recentPosts = sortedPosts.slice(0, K);

const totalCount = posts.length;

// Build a sparkline of post volume per month, oldest -> newest, last 12 months with activity
const monthKey = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;

const counts = new Map<string, number>();
for (const post of posts) {
  const d = new Date(post.frontmatter.date);
  const key = monthKey(d);
  counts.set(key, (counts.get(key) || 0) + 1);
}

const sortedKeys = Array.from(counts.keys()).sort();
const bucketKeys = sortedKeys.slice(-12); // last 12 active months
const values = bucketKeys.map((k) => counts.get(k) || 0);

const max = Math.max(1, ...values);
const width = 64;
const height = 20;
const padding = 2;
const step = values.length > 1 ? (width - padding * 2) / (values.length - 1) : 0;

const points = values.map((v, i) => {
  const x = padding + i * step;
  const y = height - padding - (v / max) * (height - padding * 2);
  return `${x.toFixed(1)},${y.toFixed(1)}`;
});

const sparklinePath = points.length > 1 ? `M${points.join(" L")}` : "";
const lastPoint = points[points.length - 1]?.split(",").map(Number);
---

<div class="space-y-8">
  <header class="pb-4 flex items-center justify-between gap-4">
    <h2 class="text-xl font-bold tracking-tight">Recent Writing</h2>

    <a
      href="/posts"
      class="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
      title={`${totalCount} posts`}
    >
      <span class="font-medium tabular-nums">{totalCount} posts</span>
      {sparklinePath && (
        <svg
          width={width}
          height={height}
          viewBox={`0 0 ${width} ${height}`}
          class="overflow-visible"
          aria-hidden="true"
        >
          <path
            d={sparklinePath}
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-zinc-400 dark:text-zinc-500"
          />
          {lastPoint && (
            <circle
              cx={lastPoint[0]}
              cy={lastPoint[1]}
              r="1.5"
              fill="currentColor"
              class="text-secondary dark:text-dk-accent"
            />
          )}
        </svg>
      )}
    </a>
  </header>

  <div class="space-y-8">
    {recentPosts.map((post: any) => (
      <article class="group">
        <div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400 mb-2">
          <time datetime={post.frontmatter.date}>{post.frontmatter.date}</time>
          {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
            <span>•</span>
            <span class="font-medium uppercase tracking-wider">{post.frontmatter.tags.join(", ")}</span>
          )}
        </div>
        <h3 class="text-lg font-semibold text-zinc-900 dark:text-white transition-colors hover:underline">
          <a href={post.url}>{post.frontmatter.title}</a>
        </h3>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
          {post.frontmatter.description}
        </p>
        <a href={post.url} class="inline-flex items-center gap-1 text-sm font-medium text-text dark:text-primary mt-3 hover:underline">
          Read article &rarr;
        </a>
      </article>
    ))}
  </div>

  <div class="pt-4 mb-5">
    <a class="text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-primary dark:hover:text-white transition-colors underline underline-offset-4" href="/posts">
      View all posts &rarr;
    </a>
    <div class="mt-6">
      <a
        href="/about"
        class="text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:text-primary dark:hover:text-white transition-colors underline underline-offset-4"
      >
        Read about Nick →
      </a>
    </div>
  </div>
</div>